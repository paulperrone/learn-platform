[
  {
    "id": "operations-rational-practice-ex1",
    "topicId": "operations-rational-practice",
    "title": "Multi-Step Problem with Fractions and Order of Operations",
    "steps": [
      {
        "subgoalLabel": "Identify the operations",
        "instruction": "Evaluate: -2/3 + 1/4 × (-6).",
        "work": "Operations present: addition and multiplication. Multiply first (order of operations).",
        "explanation": "PEMDAS: multiplication comes before addition."
      },
      {
        "subgoalLabel": "Perform multiplication",
        "instruction": "Compute 1/4 × (-6).",
        "work": "1/4 × (-6) = -6/4 = -3/2.",
        "explanation": "Multiply numerator by the integer: 1 × (-6) = -6. Simplify: -6/4 = -3/2."
      },
      {
        "subgoalLabel": "Perform addition",
        "instruction": "Now add -2/3 + (-3/2).",
        "work": "LCD of 3 and 2 is 6. -2/3 = -4/6 and -3/2 = -9/6. Sum: -4/6 + (-9/6) = -13/6.",
        "explanation": "Both are negative, so add absolute values: 4 + 9 = 13. Keep the negative: -13/6."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Write as a mixed number if desired.",
        "work": "-13/6 = -2 1/6.",
        "explanation": "13 ÷ 6 = 2 remainder 1. So -13/6 = -2 1/6."
      }
    ]
  },
  {
    "id": "operations-rational-practice-ex2",
    "topicId": "operations-rational-practice",
    "title": "Multi-Step Problem with Decimals",
    "steps": [
      {
        "subgoalLabel": "Identify the operations",
        "instruction": "Evaluate: (−0.4 + 1.6) ÷ (−0.3).",
        "work": "Parentheses first, then division.",
        "explanation": "Grouping symbols (parentheses) are done first in order of operations."
      },
      {
        "subgoalLabel": "Evaluate the parentheses",
        "instruction": "Compute -0.4 + 1.6.",
        "work": "-0.4 + 1.6 = 1.2",
        "explanation": "Different signs: 1.6 - 0.4 = 1.2. Positive is larger, so result is positive."
      },
      {
        "subgoalLabel": "Divide",
        "instruction": "Compute 1.2 ÷ (-0.3).",
        "work": "1.2 ÷ 0.3 = 4. Positive ÷ negative = negative. Answer: -4.",
        "explanation": "Move decimals: 12 ÷ 3 = 4. Apply sign rule: different signs → negative."
      }
    ]
  }
]
