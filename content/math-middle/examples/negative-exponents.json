[
  {
    "id": "negative-exponents-ex1",
    "topicId": "negative-exponents",
    "title": "Understanding 4^(-2)",
    "steps": [
      {
        "subgoalLabel": "Interpret the negative exponent",
        "instruction": "What does a negative exponent mean?",
        "work": "a^(−n) = 1/a^n. So 4^(−2) = 1/4^2.",
        "explanation": "A negative exponent means 'reciprocal.' The base moves to the denominator."
      },
      {
        "subgoalLabel": "Evaluate the positive exponent",
        "instruction": "Compute 4^2.",
        "work": "4^2 = 16",
        "explanation": "4 × 4 = 16."
      },
      {
        "subgoalLabel": "Write the final answer",
        "instruction": "Combine the results.",
        "work": "4^(−2) = 1/16",
        "explanation": "The answer is 1/16."
      }
    ]
  },
  {
    "id": "negative-exponents-ex2",
    "topicId": "negative-exponents",
    "title": "Simplifying 6a^(-3) with Positive Exponents",
    "steps": [
      {
        "subgoalLabel": "Identify the negative exponent",
        "instruction": "Which part has the negative exponent?",
        "work": "The a^(−3) has the negative exponent. The 6 is just a coefficient.",
        "explanation": "Only the variable a has a negative exponent; 6 stays in the numerator."
      },
      {
        "subgoalLabel": "Rewrite with positive exponent",
        "instruction": "Move a^(−3) to the denominator.",
        "work": "6a^(−3) = 6/a^3",
        "explanation": "a^(−3) = 1/a^3, so 6 · 1/a^3 = 6/a^3."
      },
      {
        "subgoalLabel": "Verify with a value",
        "instruction": "Check with a = 2.",
        "work": "6 · 2^(−3) = 6 · 1/8 = 6/8 = 3/4. Also: 6/2^3 = 6/8 = 3/4. ✓",
        "explanation": "Both forms give the same result."
      }
    ]
  }
]
