[
  {
    "id": "add-subtract-rationals-ex1",
    "topicId": "add-subtract-rationals",
    "title": "Adding Fractions with Different Signs",
    "steps": [
      {
        "subgoalLabel": "Find a common denominator",
        "instruction": "Add -3/5 + 1/2.",
        "work": "LCD of 5 and 2 is 10. -3/5 = -6/10 and 1/2 = 5/10.",
        "explanation": "To add fractions, we need the same denominator."
      },
      {
        "subgoalLabel": "Add the numerators",
        "instruction": "Combine -6/10 + 5/10.",
        "work": "-6 + 5 = -1. So the sum is -1/10.",
        "explanation": "Keep the denominator and add the numerators, respecting signs."
      },
      {
        "subgoalLabel": "Simplify if needed",
        "instruction": "Is -1/10 in simplest form?",
        "work": "-1/10 is already simplified. GCF(1, 10) = 1.",
        "explanation": "Always check if the result can be reduced."
      }
    ]
  },
  {
    "id": "add-subtract-rationals-ex2",
    "topicId": "add-subtract-rationals",
    "title": "Subtracting Mixed Numbers with Negatives",
    "steps": [
      {
        "subgoalLabel": "Convert to improper fractions",
        "instruction": "Compute -2 1/3 - 1 1/6.",
        "work": "-2 1/3 = -7/3 and 1 1/6 = 7/6.",
        "explanation": "Convert mixed numbers first: -2 1/3 = -(2 × 3 + 1)/3 = -7/3."
      },
      {
        "subgoalLabel": "Rewrite subtraction as addition",
        "instruction": "Change to addition of the opposite.",
        "work": "-7/3 - 7/6 = -7/3 + (-7/6)",
        "explanation": "Subtracting is the same as adding the opposite."
      },
      {
        "subgoalLabel": "Find common denominator and add",
        "instruction": "LCD of 3 and 6 is 6.",
        "work": "-7/3 = -14/6. Now: -14/6 + (-7/6) = -21/6.",
        "explanation": "Same sign (both negative): add absolute values, keep negative."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Reduce and convert to mixed number.",
        "work": "-21/6 = -7/2 = -3 1/2.",
        "explanation": "21 ÷ 3 = 7, 6 ÷ 3 = 2 → -7/2. Then 7 ÷ 2 = 3 remainder 1 → -3 1/2."
      }
    ]
  }
]
