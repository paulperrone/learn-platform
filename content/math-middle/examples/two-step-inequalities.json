    "id": "two-step-inequalities-ex1",
    "topicId": "two-step-inequalities",
    "title": "Solving 5x − 3 > 12",
    "steps": [
      {
        "subgoalLabel": "Undo subtraction",
        "instruction": "Add 3 to both sides.",
        "work": "5x − 3 + 3 > 12 + 3 → 5x > 15",
        "explanation": "Just like equations, undo addition/subtraction first."
      },
      {
        "subgoalLabel": "Undo multiplication",
        "instruction": "Divide both sides by 5.",
        "work": "x > 3",
        "explanation": "Since 5 is positive, the inequality direction stays the same."
      },
      {
        "subgoalLabel": "Check with a value",
        "instruction": "Try x = 4 (which is > 3).",
        "work": "5(4) − 3 = 20 − 3 = 17. Is 17 > 12? Yes. ✓",
        "explanation": "A value in the solution set satisfies the original inequality."
      }
    ]
  },
  {
    "id": "two-step-inequalities-ex2",
    "topicId": "two-step-inequalities",
    "title": "Solving −2n + 8 >= 14 (Negative Coefficient)",
    "steps": [
      {
        "subgoalLabel": "Undo addition",
        "instruction": "Subtract 8 from both sides.",
        "work": "−2n + 8 − 8 >= 14 − 8 → −2n >= 6",
        "explanation": "Isolate the variable term first."
      },
      {
        "subgoalLabel": "Divide by −2 and flip",
        "instruction": "Divide both sides by −2. Remember to reverse the inequality.",
        "work": "n <= −3",
        "explanation": "Dividing by a negative number reverses the inequality direction."
      },
      {
        "subgoalLabel": "Check with a value in the solution",
        "instruction": "Try n = −5 (which is <= −3).",
        "work": "−2(−5) + 8 = 10 + 8 = 18. Is 18 >= 14? Yes. ✓",
        "explanation": "The value satisfies the inequality."
      },
      {
        "subgoalLabel": "Check a value NOT in the solution",
        "instruction": "Try n = 0 (which is NOT <= −3).",
        "work": "−2(0) + 8 = 8. Is 8 >= 14? No. ✓",
        "explanation": "This confirms the boundary is correct."
      }
    ]
  }
]
