  {
    "id": "two-step-equations-ex1",
    "topicId": "two-step-equations",
    "title": "Solving 3x + 5 = 20",
    "steps": [
      {
        "subgoalLabel": "Undo addition first",
        "instruction": "Subtract 5 from both sides to isolate the term with x.",
        "work": "3x + 5 − 5 = 20 − 5 → 3x = 15",
        "explanation": "Undo operations in reverse order: addition/subtraction before multiplication/division."
      },
      {
        "subgoalLabel": "Undo multiplication",
        "instruction": "Divide both sides by 3.",
        "work": "3x / 3 = 15 / 3 → x = 5",
        "explanation": "Dividing by 3 isolates x."
      },
      {
        "subgoalLabel": "Check",
        "instruction": "Substitute x = 5 into the original equation.",
        "work": "3(5) + 5 = 15 + 5 = 20. ✓",
        "explanation": "The solution is verified."
      }
    ]
  },
  {
    "id": "two-step-equations-ex2",
    "topicId": "two-step-equations",
    "title": "Solving n/2 − 4 = 3",
    "steps": [
      {
        "subgoalLabel": "Undo subtraction",
        "instruction": "Add 4 to both sides.",
        "work": "n/2 − 4 + 4 = 3 + 4 → n/2 = 7",
        "explanation": "Adding 4 undoes the −4."
      },
      {
        "subgoalLabel": "Undo division",
        "instruction": "Multiply both sides by 2.",
        "work": "n/2 × 2 = 7 × 2 → n = 14",
        "explanation": "Multiplying by 2 undoes the division by 2."
      },
      {
        "subgoalLabel": "Check",
        "instruction": "Substitute n = 14.",
        "work": "14/2 − 4 = 7 − 4 = 3. ✓",
        "explanation": "The answer is correct."
      }
    ]
  }
]
