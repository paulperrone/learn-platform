    "title": "Subtracting 54 − 27 with Regrouping",
    "steps": [
      {
        "subgoalLabel": "Check the ones place",
        "instruction": "Can we subtract 7 from 4?",
        "work": "4 < 7, so we need to regroup.",
        "explanation": "When the bottom ones digit is bigger, we borrow a ten."
      },
      {
        "subgoalLabel": "Regroup a ten",
        "instruction": "Take 1 ten from the 5 tens and add 10 to the ones.",
        "work": "54 = 40 + 14",
        "explanation": "5 tens becomes 4 tens, and 4 ones becomes 14 ones."
      },
      {
        "subgoalLabel": "Subtract ones",
        "instruction": "Now subtract the ones: 14 − 7.",
        "work": "14 − 7 = 7",
        "explanation": "With 14 ones, we can subtract 7 to get 7 ones."
      },
      {
        "subgoalLabel": "Subtract tens",
        "instruction": "Subtract the tens: 40 − 20.",
        "work": "40 − 20 = 20",
        "explanation": "4 tens minus 2 tens equals 2 tens."
      },
      {
        "subgoalLabel": "Combine the result",
        "instruction": "Put tens and ones together.",
        "work": "20 + 7 = 27, so 54 − 27 = 27",
        "explanation": "2 tens and 7 ones make 27."
      }
    ]
  },
