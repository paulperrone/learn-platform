    "title": "Subtracting 80 − 35 by Counting Up",
    "steps": [
      {
        "subgoalLabel": "Start at the smaller number",
        "instruction": "Begin at 35 and count up to 80.",
        "work": "Start at 35",
        "explanation": "Counting up is a subtraction strategy: the distance from 35 to 80 is the answer."
      },
      {
        "subgoalLabel": "Jump to the next ten",
        "instruction": "Add 5 to get from 35 to 40.",
        "work": "35 + 5 = 40",
        "explanation": "Getting to a round number first makes the rest easier."
      },
      {
        "subgoalLabel": "Jump to the target",
        "instruction": "Add 40 to get from 40 to 80.",
        "work": "40 + 40 = 80",
        "explanation": "From 40 to 80 is a jump of 40."
      },
      {
        "subgoalLabel": "Add the jumps",
        "instruction": "Add up all the jumps: 5 + 40.",
        "work": "5 + 40 = 45, so 80 − 35 = 45",
        "explanation": "The total distance from 35 to 80 is 45, so 80 − 35 = 45."
      }
    ]
  }
