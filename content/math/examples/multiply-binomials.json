[
  {
    "id": "multiply-binomials-ex1",
    "topicId": "multiply-binomials",
    "title": "Multiplying Binomials Using FOIL",
    "steps": [
      {
        "subgoalLabel": "Set up FOIL",
        "instruction": "FOIL stands for First, Outer, Inner, Last — the four products when multiplying two binomials.",
        "work": "(x + 3)(x + 5): F = x·x, O = x·5, I = 3·x, L = 3·5",
        "explanation": "Each term in the first binomial multiplies each term in the second."
      },
      {
        "subgoalLabel": "Calculate each product",
        "instruction": "Multiply each pair.",
        "work": "F = x². O = 5x. I = 3x. L = 15.",
        "explanation": "You get four terms before combining."
      },
      {
        "subgoalLabel": "Combine like terms",
        "instruction": "Add the middle terms (Outer + Inner).",
        "work": "x² + 5x + 3x + 15 = x² + 8x + 15",
        "explanation": "The two middle terms are like terms and combine into one."
      }
    ]
  },
  {
    "id": "multiply-binomials-ex2",
    "topicId": "multiply-binomials",
    "title": "Multiplying Binomials with Negative Terms",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Multiply (2x − 3)(x + 4).",
        "work": "F = 2x·x, O = 2x·4, I = (−3)·x, L = (−3)·4",
        "explanation": "Treat the −3 as negative when multiplying."
      },
      {
        "subgoalLabel": "Calculate",
        "instruction": "Multiply each pair carefully.",
        "work": "F = 2x². O = 8x. I = −3x. L = −12.",
        "explanation": "Watch signs: negative × positive = negative."
      },
      {
        "subgoalLabel": "Combine",
        "instruction": "Add middle terms and write in standard form.",
        "work": "2x² + 8x − 3x − 12 = 2x² + 5x − 12",
        "explanation": "8x + (−3x) = 5x."
      }
    ]
  }
]