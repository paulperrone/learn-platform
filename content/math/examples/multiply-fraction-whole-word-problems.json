    "title": "Paint for Multiple Rooms",
    "steps": [
      {
        "subgoalLabel": "Identify the information",
        "instruction": "Each room needs 2/3 gallon of paint. We need to paint 6 rooms.",
        "work": "6 rooms × 2/3 gallon per room",
        "explanation": "We multiply the number of rooms by the amount per room."
      },
      {
        "subgoalLabel": "Multiply",
        "instruction": "Multiply 6 × 2/3: multiply 6 × 2, then put over 3.",
        "work": "6 × 2/3 = 12/3",
        "explanation": "6 times the numerator 2 is 12, over the denominator 3."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Divide 12 by 3 to simplify.",
        "work": "12/3 = 4",
        "explanation": "12 divided by 3 is 4, so we need 4 gallons of paint."
      }
    ]
  },
  {
    "id": "multiply-fraction-whole-word-problems-ex2",
    "topicId": "multiply-fraction-whole-word-problems",
    "title": "Flour for Multiple Batches",
    "steps": [
      {
        "subgoalLabel": "Identify the information",
        "instruction": "Each batch uses 3/4 cup of flour. We are making 5 batches.",
        "work": "5 × 3/4",
        "explanation": "Multiply the number of batches by the flour per batch."
      },
      {
        "subgoalLabel": "Multiply",
        "instruction": "Multiply 5 × 3 and keep the denominator 4.",
        "work": "5 × 3/4 = 15/4",
        "explanation": "5 times 3 is 15, over 4."
      },
      {
        "subgoalLabel": "Convert to mixed number",
        "instruction": "Divide 15 by 4: 15 ÷ 4 = 3 remainder 3.",
        "work": "15/4 = 3 3/4",
        "explanation": "We need 3 3/4 cups of flour for 5 batches."
      }
    ]
  }
