[
  {"id":"convert-volume-ex1","topicId":"convert-volume","title":"Converting Gallons to Cups","steps":[{"subgoalLabel":"Know the chain","instruction":"1 gal = 4 qt, 1 qt = 2 pt, 1 pt = 2 cups.","work":"Convert 2 gallons to cups.","explanation":"Multiply through the chain."},{"subgoalLabel":"Convert step by step","instruction":"Gallons → quarts → pints → cups.","work":"2 gal = 8 qt = 16 pt = 32 cups","explanation":"At each step, multiply by the conversion factor."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"2 gallons = 32 cups","explanation":"Or simply: 1 gallon = 16 cups, so 2 × 16 = 32."}]},
  {"id":"convert-volume-ex2","topicId":"convert-volume","title":"Converting mL to Liters","steps":[{"subgoalLabel":"Know the conversion","instruction":"1,000 mL = 1 L.","work":"Convert 3,750 mL to liters.","explanation":"Divide by 1,000."},{"subgoalLabel":"Divide","instruction":"3,750 ÷ 1,000.","work":"3,750 ÷ 1,000 = 3.75 L","explanation":"Move the decimal point 3 places left."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"3,750 mL = 3.75 L (or 3 L 750 mL)","explanation":"Both forms are correct."}]}
]
