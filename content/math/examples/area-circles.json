[
  {
    "id": "area-circles-ex1",
    "topicId": "area-circles",
    "title": "Finding the Area of a Circle",
    "steps": [
      {
        "subgoalLabel": "Recall the formula",
        "instruction": "Area = π × r², where r is the radius.",
        "work": "A = πr²",
        "explanation": "You must square the radius first, then multiply by pi."
      },
      {
        "subgoalLabel": "Substitute",
        "instruction": "A circle has radius 4 cm.",
        "work": "A = π × 4² = π × 16",
        "explanation": "Square 4 to get 16."
      },
      {
        "subgoalLabel": "Calculate",
        "instruction": "Exact: 16π sq cm. Approximate: 16 × 3.14.",
        "work": "A ≈ 50.24 sq cm",
        "explanation": "The area is 16π sq cm exactly, or about 50.24 sq cm."
      }
    ]
  },
  {
    "id": "area-circles-ex2",
    "topicId": "area-circles",
    "title": "Area of a Circle Given Diameter",
    "steps": [
      {
        "subgoalLabel": "Find the radius",
        "instruction": "A circle has diameter 20 cm. Find the radius first.",
        "work": "r = 20 ÷ 2 = 10 cm",
        "explanation": "Radius is half the diameter."
      },
      {
        "subgoalLabel": "Apply the formula",
        "instruction": "Use A = πr².",
        "work": "A = π × 10² = 100π sq cm",
        "explanation": "The exact area is 100π sq cm."
      },
      {
        "subgoalLabel": "Approximate if needed",
        "instruction": "Use pi ≈ 3.14.",
        "work": "A ≈ 314 sq cm",
        "explanation": "100 × 3.14 = 314 sq cm."
      }
    ]
  }
]