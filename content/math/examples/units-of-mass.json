  {"id":"units-of-mass-ex1","topicId":"units-of-mass","title":"Converting Pounds to Ounces","steps":[{"subgoalLabel":"Know the conversion","instruction":"How many ounces in 1 pound?","work":"1 pound = 16 ounces","explanation":"Key fact for mass conversions."},{"subgoalLabel":"Multiply","instruction":"Convert 3 pounds to ounces.","work":"3 × 16 = 48 ounces","explanation":"Multiply pounds by 16."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"3 pounds = 48 ounces","explanation":"Larger to smaller unit means multiply."}]},
