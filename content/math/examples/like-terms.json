[
  {"id":"like-terms-ex1","topicId":"like-terms","title":"Combining Like Terms","steps":[{"subgoalLabel":"Identify like terms","instruction":"Look for terms with the same variable.","work":"In 4x + 3y + 2x + 5y: x-terms are 4x and 2x; y-terms are 3y and 5y.","explanation":"Like terms have the same variable."},{"subgoalLabel":"Combine x-terms","instruction":"Add the coefficients of x.","work":"4x + 2x = 6x","explanation":"4 + 2 = 6, keep the variable x."},{"subgoalLabel":"Combine y-terms","instruction":"Add the coefficients of y.","work":"3y + 5y = 8y","explanation":"3 + 5 = 8, keep the variable y."},{"subgoalLabel":"Write simplified expression","instruction":"Put it together.","work":"6x + 8y","explanation":"The simplified expression has only one term for each variable."}]},
  {"id":"like-terms-ex2","topicId":"like-terms","title":"Combining with Subtraction and Constants","steps":[{"subgoalLabel":"Group like terms","instruction":"Find terms with the same variable.","work":"7a − 3 + 2a + 5: a-terms: 7a, 2a. Constants: −3, 5.","explanation":"Constants (numbers without variables) are like terms with each other."},{"subgoalLabel":"Combine variable terms","instruction":"Add coefficients of a.","work":"7a + 2a = 9a","explanation":"7 + 2 = 9."},{"subgoalLabel":"Combine constants","instruction":"Add the constant terms.","work":"−3 + 5 = 2","explanation":"−3 + 5 = 2."},{"subgoalLabel":"Final answer","instruction":"Write the simplified expression.","work":"9a + 2","explanation":"From 4 terms down to 2."}]}
]
