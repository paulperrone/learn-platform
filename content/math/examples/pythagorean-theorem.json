[
  {
    "id": "pythagorean-theorem-ex1",
    "topicId": "pythagorean-theorem",
    "title": "Finding the Hypotenuse",
    "steps": [
      {
        "subgoalLabel": "State the theorem",
        "instruction": "In a right triangle, a² + b² = c², where c is the hypotenuse (longest side, opposite the right angle).",
        "work": "a² + b² = c²",
        "explanation": "This only works for right triangles."
      },
      {
        "subgoalLabel": "Substitute",
        "instruction": "Legs are 5 and 12. Find the hypotenuse.",
        "work": "5² + 12² = c² → 25 + 144 = c² → 169 = c²",
        "explanation": "Square each leg and add."
      },
      {
        "subgoalLabel": "Solve",
        "instruction": "Take the square root.",
        "work": "c = √169 = 13",
        "explanation": "The hypotenuse is 13."
      }
    ]
  },
  {
    "id": "pythagorean-theorem-ex2",
    "topicId": "pythagorean-theorem",
    "title": "Finding a Leg",
    "steps": [
      {
        "subgoalLabel": "Rearrange the formula",
        "instruction": "If you know the hypotenuse and one leg, solve for the other: a² = c² − b².",
        "work": "a² = c² − b²",
        "explanation": "Isolate the unknown leg by subtracting."
      },
      {
        "subgoalLabel": "Substitute",
        "instruction": "Hypotenuse = 10, one leg = 6.",
        "work": "a² = 10² − 6² = 100 − 36 = 64",
        "explanation": "Square the hypotenuse and subtract the square of the known leg."
      },
      {
        "subgoalLabel": "Solve",
        "instruction": "Take the square root.",
        "work": "a = √64 = 8",
        "explanation": "The missing leg is 8."
      }
    ]
  }
]