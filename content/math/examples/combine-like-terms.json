[
  {
    "id": "combine-like-terms-ex1",
    "topicId": "combine-like-terms",
    "title": "Combining Like Terms: 4x + 7 − x + 3",
    "steps": [
      {
        "subgoalLabel": "Identify like terms",
        "instruction": "Which terms are like terms?",
        "work": "x-terms: 4x and −x. Constants: 7 and 3.",
        "explanation": "Like terms have the same variable raised to the same power."
      },
      {
        "subgoalLabel": "Combine x-terms",
        "instruction": "Add 4x + (−x).",
        "work": "4x − x = 3x",
        "explanation": "Remember that −x means −1x. So 4 − 1 = 3."
      },
      {
        "subgoalLabel": "Combine constants",
        "instruction": "Add 7 + 3.",
        "work": "7 + 3 = 10",
        "explanation": "Add the constant terms together."
      },
      {
        "subgoalLabel": "Write the result",
        "instruction": "Combine the simplified parts.",
        "work": "3x + 10",
        "explanation": "The expression 4x + 7 − x + 3 simplifies to 3x + 10."
      }
    ]
  },
  {
    "id": "combine-like-terms-ex2",
    "topicId": "combine-like-terms",
    "title": "Combining Like Terms with Multiple Variable Types: 2a + 5b − 3a + b + 4",
    "steps": [
      {
        "subgoalLabel": "Group by variable",
        "instruction": "Identify and group like terms.",
        "work": "a-terms: 2a, −3a. b-terms: 5b, b. Constants: 4.",
        "explanation": "Terms with 'a' are like terms with each other, terms with 'b' with each other."
      },
      {
        "subgoalLabel": "Combine a-terms",
        "instruction": "Add 2a + (−3a).",
        "work": "2a − 3a = −a",
        "explanation": "2 − 3 = −1, so we get −1a, written as −a."
      },
      {
        "subgoalLabel": "Combine b-terms",
        "instruction": "Add 5b + b.",
        "work": "5b + b = 6b",
        "explanation": "b means 1b. So 5 + 1 = 6."
      },
      {
        "subgoalLabel": "Write the result",
        "instruction": "Put all simplified parts together.",
        "work": "−a + 6b + 4",
        "explanation": "Each group of like terms has been combined into a single term."
      }
    ]
  }
]
