[
  {
    "id": "division-with-zeros-ex1",
    "topicId": "division-with-zeros",
    "title": "A Zero in the Middle of the Quotient",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 612 ÷ 6 using long division.",
        "work": "Write 6 outside and 612 inside.",
        "explanation": "This problem has a common trap — a zero appears in the quotient."
      },
      {
        "subgoalLabel": "Divide the first digit",
        "instruction": "6 ÷ 6 = ?",
        "work": "6 ÷ 6 = 1. Write 1. Subtract: 6 - 6 = 0.",
        "explanation": "First quotient digit is 1."
      },
      {
        "subgoalLabel": "Bring down — number too small",
        "instruction": "Bring down 1. Can 6 go into 1?",
        "work": "1 ÷ 6 = 0. Write 0 in the quotient. Subtract: 1 - 0 = 1.",
        "explanation": "IMPORTANT: when the number is smaller than the divisor, you must write 0, not skip it."
      },
      {
        "subgoalLabel": "Continue",
        "instruction": "Bring down 2. 12 ÷ 6 = ?",
        "work": "12 ÷ 6 = 2. Write 2. Subtract: 12 - 12 = 0.",
        "explanation": "The final quotient digit is 2."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient.",
        "work": "612 ÷ 6 = 102 (not 12!).",
        "explanation": "The zero is a placeholder that keeps the 1 in the hundreds place and the 2 in the ones place. Check: 102 × 6 = 612 ✓."
      }
    ]
  },
  {
    "id": "division-with-zeros-ex2",
    "topicId": "division-with-zeros",
    "title": "Multiple Zeros in the Quotient",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 5025 ÷ 5.",
        "work": "Write 5 outside and 5025 inside.",
        "explanation": "This quotient will have two zeros in a row."
      },
      {
        "subgoalLabel": "Divide 5 by 5",
        "instruction": "5 ÷ 5 = ?",
        "work": "5 ÷ 5 = 1. Write 1. Subtract: 5 - 5 = 0.",
        "explanation": "First digit done."
      },
      {
        "subgoalLabel": "Bring down 0",
        "instruction": "Bring down 0. 0 ÷ 5 = ?",
        "work": "0 ÷ 5 = 0. Write 0.",
        "explanation": "Zero divided by any number is 0."
      },
      {
        "subgoalLabel": "Bring down 2",
        "instruction": "Bring down 2. 2 ÷ 5 = ?",
        "work": "2 ÷ 5 = 0 R 2. Write 0.",
        "explanation": "2 is less than 5, so another zero in the quotient."
      },
      {
        "subgoalLabel": "Bring down 5",
        "instruction": "Bring down 5 to make 25. 25 ÷ 5 = ?",
        "work": "25 ÷ 5 = 5. Write 5. Subtract: 25 - 25 = 0.",
        "explanation": "Final digit."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient.",
        "work": "5025 ÷ 5 = 1005.",
        "explanation": "Check: 1005 × 5 = 5025 ✓. Every zero matters!"
      }
    ]
  }
]
