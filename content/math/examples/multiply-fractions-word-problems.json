    "title": "Scaling a Recipe Down",
    "steps": [
      {
        "subgoalLabel": "Understand the problem",
        "instruction": "A recipe needs 4/5 cup of milk. You want to make 1/2 of the recipe. How much milk?",
        "work": "1/2 × 4/5",
        "explanation": "Making half the recipe means multiplying each ingredient by 1/2."
      },
      {
        "subgoalLabel": "Multiply the fractions",
        "instruction": "Multiply numerators and denominators.",
        "work": "(1 × 4) / (2 × 5) = 4/10",
        "explanation": "1 times 4 is 4; 2 times 5 is 10."
      },
      {
        "subgoalLabel": "Simplify the answer",
