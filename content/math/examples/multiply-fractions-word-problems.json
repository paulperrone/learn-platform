    "title": "Finding a Fraction of a Fraction: Garden Plot",
    "steps": [
      {
        "subgoalLabel": "Understand the problem",
        "instruction": "A garden is 3/4 acre. Vegetables cover 2/3 of the garden. Find the area covered by vegetables.",
        "work": "2/3 of 3/4 = 2/3 × 3/4",
        "explanation": "'Of' in fraction problems means multiply."
      },
      {
        "subgoalLabel": "Multiply numerators and denominators",
        "instruction": "Multiply across: numerators together, denominators together.",
        "work": "(2 × 3) / (3 × 4) = 6/12",
        "explanation": "2 times 3 is 6; 3 times 4 is 12."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Divide both 6 and 12 by their GCF, which is 6.",
        "work": "6/12 = 1/2",
        "explanation": "The vegetable area is 1/2 acre."
      }
    ]
