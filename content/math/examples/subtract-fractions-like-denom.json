    "title": "Subtracting Fractions with the Same Denominator: 5/8 − 2/8",
    "steps": [
      {
        "subgoalLabel": "Check the denominators",
        "instruction": "Are the denominators the same?",
        "work": "Both fractions have denominator 8. Yes!",
        "explanation": "When denominators match, subtract the numerators and keep the denominator."
      },
      {
        "subgoalLabel": "Subtract the numerators",
        "instruction": "Subtract: 5 − 2.",
        "work": "5/8 − 2/8 = (5−2)/8 = 3/8",
        "explanation": "5 eighths minus 2 eighths equals 3 eighths."
      },
      {
        "subgoalLabel": "Simplify if needed",
        "instruction": "Is 3/8 in simplest form?",
        "work": "GCF(3, 8) = 1. Already simplified.",
        "explanation": "3 and 8 share no common factors, so 3/8 is the final answer."
      }
    ]
