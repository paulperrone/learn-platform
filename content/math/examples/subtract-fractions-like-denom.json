    "title": "Subtracting from 1 Whole: 1 − 3/5",
    "steps": [
      {
        "subgoalLabel": "Rewrite 1 as a fraction",
        "instruction": "Write 1 with the same denominator as 3/5.",
        "work": "1 = 5/5",
        "explanation": "Any whole number can be written as a fraction. 1 = 5/5 because 5 fifths make one whole."
      },
      {
        "subgoalLabel": "Subtract",
        "instruction": "Now subtract: 5/5 − 3/5.",
        "work": "5/5 − 3/5 = 2/5",
        "explanation": "5 fifths minus 3 fifths equals 2 fifths."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Write the final answer.",
        "work": "1 − 3/5 = 2/5",
        "explanation": "When subtracting a fraction from 1, rewrite 1 with the same denominator, then subtract numerators."
      }
    ]
