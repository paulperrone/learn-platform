[
  {
    "id": "multiply-mixed-fractions-ex1",
    "topicId": "multiply-mixed-fractions",
    "title": "Multiplying 2 1/2 × 3/4",
    "steps": [
      {
        "subgoalLabel": "Convert the mixed number",
        "instruction": "Convert 2 1/2 to an improper fraction.",
        "work": "2 1/2 = (2 × 2 + 1)/2 = 5/2",
        "explanation": "Multiply the whole number by the denominator, add the numerator."
      },
      {
        "subgoalLabel": "Multiply the fractions",
        "instruction": "Multiply 5/2 × 3/4.",
        "work": "(5 × 3) / (2 × 4) = 15/8",
        "explanation": "Multiply numerators together and denominators together."
      },
      {
        "subgoalLabel": "Convert to mixed number",
        "instruction": "Divide 15 by 8: 15 ÷ 8 = 1 remainder 7.",
        "work": "15/8 = 1 7/8",
        "explanation": "2 1/2 × 3/4 = 1 7/8."
      }
    ]
  },
  {
    "id": "multiply-mixed-fractions-ex2",
    "topicId": "multiply-mixed-fractions",
    "title": "Multiplying 1 2/3 × 3/5",
    "steps": [
      {
        "subgoalLabel": "Convert the mixed number",
        "instruction": "Convert 1 2/3 to an improper fraction.",
        "work": "1 2/3 = (1 × 3 + 2)/3 = 5/3",
        "explanation": "1 whole is 3 thirds, plus 2 thirds is 5 thirds."
      },
      {
        "subgoalLabel": "Multiply",
        "instruction": "Multiply 5/3 × 3/5.",
        "work": "(5 × 3) / (3 × 5) = 15/15",
        "explanation": "Notice the numerator and denominator are the same."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Simplify 15/15.",
        "work": "15/15 = 1",
        "explanation": "Any number divided by itself equals 1. So 1 2/3 × 3/5 = 1."
      }
    ]
  }
]
