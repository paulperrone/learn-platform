[
  {"id":"construct-algebraic-expressions-ex1","topicId":"construct-algebraic-expressions","title":"Translating 'Twice a Number Plus 7'","steps":[{"subgoalLabel":"Identify parts","instruction":"Break the phrase into operations.","work":"'Twice a number' = 2 × n = 2n. 'Plus 7' = + 7.","explanation":"'Twice' means multiply by 2, 'plus' means add."},{"subgoalLabel":"Combine","instruction":"Put the parts together.","work":"2n + 7","explanation":"The expression is 2n + 7."},{"subgoalLabel":"Verify","instruction":"Test with n = 3.","work":"2(3) + 7 = 6 + 7 = 13. Is 13 twice 3 plus 7? 2×3=6, 6+7=13 ✓","explanation":"The expression correctly represents the phrase."}]},
  {"id":"construct-algebraic-expressions-ex2","topicId":"construct-algebraic-expressions","title":"Real-World Expression: Cost Calculation","steps":[{"subgoalLabel":"Read the scenario","instruction":"A movie ticket costs d dollars. Popcorn costs $5.","work":"d = ticket price, $5 = popcorn","explanation":"We need an expression for the total cost of 2 tickets and popcorn."},{"subgoalLabel":"Write ticket cost","instruction":"2 tickets at d dollars each.","work":"2 × d = 2d","explanation":"Multiply quantity by price."},{"subgoalLabel":"Add popcorn","instruction":"Add $5 for popcorn.","work":"2d + 5","explanation":"Total cost = ticket cost + popcorn."},{"subgoalLabel":"Test it","instruction":"If tickets are $8 each, what's the total?","work":"2(8) + 5 = 16 + 5 = $21","explanation":"2 tickets at $8 = $16, plus $5 popcorn = $21. Makes sense!"}]}
]
