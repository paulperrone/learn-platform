    "title": "Dividing by 4 by Halving Twice",
    "steps": [
      {
        "subgoalLabel": "Set up the problem",
        "instruction": "Find 44 ÷ 4.",
        "work": "We need to split 44 into 4 equal groups.",
        "explanation": "Dividing by 4 can be tricky, but there is a shortcut: divide by 2 twice."
      },
      {
        "subgoalLabel": "First halving",
        "instruction": "Divide 44 by 2.",
        "work": "44 ÷ 2 = 22.",
        "explanation": "Half of 44 is 22."
      },
      {
        "subgoalLabel": "Second halving",
        "instruction": "Divide 22 by 2.",
        "work": "22 ÷ 2 = 11.",
        "explanation": "Half of 22 is 11."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Write the final answer.",
        "work": "44 ÷ 4 = 11.",
        "explanation": "Dividing by 2 twice is the same as dividing by 4, because 2 × 2 = 4. Check: 11 × 4 = 44 ✓"
      }
    ]
  }
