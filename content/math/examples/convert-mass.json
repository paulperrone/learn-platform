[
  {"id":"convert-mass-ex1","topicId":"convert-mass","title":"Converting Ounces to Pounds and Ounces","steps":[{"subgoalLabel":"Know the conversion","instruction":"16 oz = 1 lb.","work":"Convert 52 ounces to pounds and ounces.","explanation":"Divide by 16."},{"subgoalLabel":"Divide","instruction":"52 ÷ 16.","work":"52 ÷ 16 = 3 remainder 4","explanation":"3 full pounds with 4 ounces remaining."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"52 oz = 3 lb 4 oz","explanation":"Check: 3 × 16 + 4 = 48 + 4 = 52 ✓"}]},
  {"id":"convert-mass-ex2","topicId":"convert-mass","title":"Comparing Weights in Different Units","steps":[{"subgoalLabel":"Read the problem","instruction":"Is 2.5 kg more or less than 3,000 g?","work":"We need to convert to the same unit.","explanation":"Can't compare different units directly."},{"subgoalLabel":"Convert","instruction":"Convert 2.5 kg to grams.","work":"2.5 × 1,000 = 2,500 g","explanation":"Now both are in grams."},{"subgoalLabel":"Compare","instruction":"2,500 g vs 3,000 g.","work":"2,500 < 3,000","explanation":"3,000 g is heavier than 2.5 kg."}]}
