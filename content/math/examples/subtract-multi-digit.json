[
  {
    "id": "subtract-multi-digit-ex1",
    "topicId": "subtract-multi-digit",
    "title": "Subtracting Four-Digit Numbers With Regrouping",
    "steps": [
      {
        "subgoalLabel": "Set up the problem",
        "instruction": "Find 8,312 − 4,675.",
        "work": "Line up by place value: thousands, hundreds, tens, ones.",
        "explanation": "We subtract from right to left, regrouping whenever the top digit is smaller."
      },
      {
        "subgoalLabel": "Subtract ones (regroup)",
        "instruction": "2 < 5, so regroup from tens.",
        "work": "1 ten → 10 ones. 12 − 5 = 7.",
        "explanation": "Borrow 1 ten, making 0 tens and 12 ones."
      },
      {
        "subgoalLabel": "Subtract tens (regroup)",
        "instruction": "0 < 7, so regroup from hundreds.",
        "work": "3 hundreds → 2 hundreds, 0 tens → 10 tens. 10 − 7 = 3.",
        "explanation": "Borrow 1 hundred to make 10 tens."
      },
      {
        "subgoalLabel": "Subtract hundreds (regroup)",
        "instruction": "2 < 6, so regroup from thousands.",
        "work": "8 thousands → 7 thousands, 2 hundreds → 12 hundreds. 12 − 6 = 6.",
        "explanation": "Borrow 1 thousand to make 12 hundreds."
      },
      {
        "subgoalLabel": "Subtract thousands",
        "instruction": "7 − 4 = ?",
        "work": "7 − 4 = 3.",
        "explanation": "No more regrouping needed."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 8,312 − 4,675?",
        "work": "8,312 − 4,675 = 3,637.",
        "explanation": "Three regroupings were needed because the ones, tens, and hundreds each had a top digit smaller than the bottom."
      }
    ]
  },
  {
    "id": "subtract-multi-digit-ex2",
    "topicId": "subtract-multi-digit",
    "title": "Subtracting Across Zeros in a Large Number",
    "steps": [
      {
        "subgoalLabel": "Set up the problem",
        "instruction": "Find 10,000 − 4,567.",
        "work": "10,000 has four zeros. We must regroup from the ten-thousands.",
        "explanation": "This is like subtracting across zeros, but with more places."
      },
      {
        "subgoalLabel": "Regroup across all zeros",
        "instruction": "Convert 10,000 into usable digits.",
        "work": "10,000 → 9 thousands, 9 hundreds, 9 tens, 10 ones.",
        "explanation": "Borrow 1 ten-thousand → 10 thousands. Then borrow through each place until ones has 10."
      },
      {
        "subgoalLabel": "Subtract all places",
        "instruction": "Subtract each place: ones, tens, hundreds, thousands.",
        "work": "Ones: 10 − 7 = 3. Tens: 9 − 6 = 3. Hundreds: 9 − 5 = 4. Thousands: 9 − 4 = 5.",
        "explanation": "After regrouping, each subtraction is simple."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 10,000 − 4,567?",
        "work": "10,000 − 4,567 = 5,433.",
        "explanation": "The pattern for subtracting from 10,000: regroup to 9-9-9-10 then subtract."
      }
    ]
  }
]
