    "title": "Dividing 6 ÷ 2/3",
    "steps": [
      {
        "subgoalLabel": "Find the reciprocal",
        "instruction": "The reciprocal of 2/3 is 3/2.",
        "work": "Reciprocal of 2/3 = 3/2",
        "explanation": "Flip the fraction to find the reciprocal."
      },
      {
        "subgoalLabel": "Multiply",
        "instruction": "Multiply 6 by the reciprocal.",
        "work": "6 × 3/2 = 18/2",
        "explanation": "6 times 3 is 18, over 2."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Divide 18 by 2.",
        "work": "18/2 = 9",
        "explanation": "6 ÷ 2/3 = 9. There are 9 groups of 2/3 in 6."
      }
    ]
