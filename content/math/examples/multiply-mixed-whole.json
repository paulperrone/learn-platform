[
  {
    "id": "multiply-mixed-whole-ex1",
    "topicId": "multiply-mixed-whole",
    "title": "Multiplying 2 1/3 × 4",
    "steps": [
      {
        "subgoalLabel": "Convert to improper fraction",
        "instruction": "Convert 2 1/3 to an improper fraction: multiply 2 × 3, add 1.",
        "work": "2 1/3 = (2 × 3 + 1)/3 = 7/3",
        "explanation": "2 wholes is 6 thirds, plus 1 third is 7 thirds."
      },
      {
        "subgoalLabel": "Multiply by the whole number",
        "instruction": "Multiply 7/3 × 4.",
        "work": "7/3 × 4 = 28/3",
        "explanation": "Multiply the numerator by 4: 7 × 4 = 28. Denominator stays 3."
      },
      {
        "subgoalLabel": "Convert back to mixed number",
        "instruction": "Divide 28 by 3: 28 ÷ 3 = 9 remainder 1.",
        "work": "28/3 = 9 1/3",
        "explanation": "2 1/3 × 4 = 9 1/3."
      }
    ]
  },
  {
    "id": "multiply-mixed-whole-ex2",
    "topicId": "multiply-mixed-whole",
    "title": "Multiplying 1 3/4 × 6",
    "steps": [
      {
        "subgoalLabel": "Convert to improper fraction",
        "instruction": "Convert 1 3/4: multiply 1 × 4, add 3.",
        "work": "1 3/4 = (1 × 4 + 3)/4 = 7/4",
        "explanation": "1 whole is 4 fourths, plus 3 fourths is 7 fourths."
      },
      {
        "subgoalLabel": "Multiply",
        "instruction": "Multiply 7/4 × 6.",
        "work": "7/4 × 6 = 42/4",
        "explanation": "7 × 6 = 42 over 4."
      },
      {
        "subgoalLabel": "Simplify and convert",
        "instruction": "Simplify 42/4 = 21/2, then convert to a mixed number.",
        "work": "42/4 = 21/2 = 10 1/2",
        "explanation": "1 3/4 × 6 = 10 1/2."
      }
    ]
  }
]
