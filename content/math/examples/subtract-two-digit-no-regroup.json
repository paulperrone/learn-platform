    "steps": [
      {
        "subgoalLabel": "Set up the problem",
        "instruction": "Find 67 − 23.",
        "work": "Line up the digits by place value: tens over tens, ones over ones.",
        "explanation": "Keeping digits lined up helps us subtract each place correctly."
      },
      {
        "subgoalLabel": "Subtract the ones",
        "instruction": "Subtract the ones digits: 7 − 3.",
        "work": "7 − 3 = 4. Write 4 in the ones place.",
        "explanation": "Always start with the ones place."
      },
      {
        "subgoalLabel": "Subtract the tens",
        "instruction": "Subtract the tens digits: 6 − 2.",
        "work": "6 − 2 = 4. Write 4 in the tens place.",
        "explanation": "Since 3 < 7 and 2 < 6, no regrouping was needed."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the result.",
        "work": "67 − 23 = 44.",
        "explanation": "We subtracted each place separately and combined the results."
      }
