    "title": "Two-Digit Subtraction in a Word Problem",
    "steps": [
      {
        "subgoalLabel": "Read the problem",
        "instruction": "A farmer has 89 apples. He sells 45. How many are left?",
        "work": "We need to find 89 − 45.",
        "explanation": "Selling means taking away, so we subtract."
      },
      {
        "subgoalLabel": "Subtract the ones",
        "instruction": "9 − 5 = ?",
        "work": "9 − 5 = 4.",
        "explanation": "The ones digit of the answer is 4."
      },
      {
        "subgoalLabel": "Subtract the tens",
        "instruction": "8 − 4 = ?",
        "work": "8 − 4 = 4.",
        "explanation": "The tens digit of the answer is 4."
      },
      {
        "subgoalLabel": "Answer the question",
        "instruction": "How many apples are left?",
        "work": "89 − 45 = 44. The farmer has 44 apples left.",
        "explanation": "No regrouping was needed because each bottom digit was smaller than the top digit."
      }
    ]
  }
