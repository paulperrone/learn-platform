    "topicId": "multiply-by-3-4",
    "title": "Multiplying by 3 Using Known Facts",
    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Find 3 × 8.",
        "work": "3 × 8 means 3 groups of 8.",
        "explanation": "We need to find the total when there are 3 groups with 8 in each."
      },
      {
        "subgoalLabel": "Break it into known facts",
        "instruction": "Use 2 × 8 to help.",
        "work": "2 × 8 = 16.",
        "explanation": "We already know the 2s facts. 3 groups is just one more group than 2 groups."
      },
      {
        "subgoalLabel": "Add one more group",
        "instruction": "Add one more group of 8.",
        "work": "16 + 8 = 24.",
        "explanation": "3 × 8 = 2 × 8 + 8 = 16 + 8 = 24."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 3 × 8?",
        "work": "3 × 8 = 24",
        "explanation": "Strategy: use a known × 2 fact and add one more group."
      }
    ]
  },
  {
    "id": "multiply-by-3-4-ex2",
