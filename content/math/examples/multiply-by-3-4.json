    "title": "Multiplying by 4 Using the Doubling Strategy",
    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Find 4 × 7.",
        "work": "4 × 7 means 4 groups of 7.",
        "explanation": "Multiplying by 4 can be done by doubling twice."
      },
      {
        "subgoalLabel": "Double once",
        "instruction": "Find 2 × 7.",
        "work": "2 × 7 = 14.",
        "explanation": "First, find 2 groups of 7 by doubling 7."
      },
      {
        "subgoalLabel": "Double again",
        "instruction": "Double the result.",
        "work": "2 × 14 = 28.",
        "explanation": "4 groups is double 2 groups. So double 14 to get 28."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 4 × 7?",
        "work": "4 × 7 = 28",
        "explanation": "Strategy: 4 × n = 2 × (2 × n). Double 7 = 14, double 14 = 28."
      }
    ]
  }
