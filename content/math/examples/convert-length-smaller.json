[
  {"id":"convert-length-smaller-ex1","topicId":"convert-length-smaller","title":"Converting Feet to Inches","steps":[{"subgoalLabel":"Know the conversion","instruction":"1 foot = 12 inches.","work":"We need to convert 4 feet 7 inches to inches only.","explanation":"Convert the feet first, then add the extra inches."},{"subgoalLabel":"Convert feet","instruction":"Multiply feet by 12.","work":"4 × 12 = 48 inches","explanation":"4 feet equals 48 inches."},{"subgoalLabel":"Add remaining inches","instruction":"Add the 7 inches.","work":"48 + 7 = 55 inches","explanation":"4 feet 7 inches = 55 inches total."}]},
  {"id":"convert-length-smaller-ex2","topicId":"convert-length-smaller","title":"Converting Meters to Centimeters","steps":[{"subgoalLabel":"Know the conversion","instruction":"1 m = 100 cm.","work":"Convert 2 m 35 cm to centimeters only.","explanation":"Multiply meters by 100 and add the remaining cm."},{"subgoalLabel":"Convert meters","instruction":"Multiply.","work":"2 × 100 = 200 cm","explanation":"2 meters is 200 centimeters."},{"subgoalLabel":"Add remaining","instruction":"Add 35 cm.","work":"200 + 35 = 235 cm","explanation":"2 m 35 cm = 235 cm."}]}
]
