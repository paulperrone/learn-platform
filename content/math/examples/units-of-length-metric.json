[
  {"id":"units-of-length-metric-ex1","topicId":"units-of-length-metric","title":"Converting Meters to Centimeters","steps":[{"subgoalLabel":"Know the conversion","instruction":"How many cm in 1 m?","work":"1 m = 100 cm","explanation":"Metric conversions use powers of 10."},{"subgoalLabel":"Multiply","instruction":"Convert 3.5 m to cm.","work":"3.5 × 100 = 350 cm","explanation":"Multiply meters by 100 to get centimeters."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"3.5 m = 350 cm","explanation":"Moving from larger to smaller units, multiply."}]},
  {"id":"units-of-length-metric-ex2","topicId":"units-of-length-metric","title":"Comparing Metric Units","steps":[{"subgoalLabel":"Convert to same units","instruction":"Compare 250 cm and 3 m.","work":"3 m = 300 cm","explanation":"Convert to the same unit to compare."},{"subgoalLabel":"Compare","instruction":"Which is longer?","work":"300 cm > 250 cm, so 3 m is longer.","explanation":"Now we can compare directly."},{"subgoalLabel":"Find the difference","instruction":"How much longer?","work":"300 − 250 = 50 cm","explanation":"3 m is 50 cm longer than 250 cm."}]}
