    "title": "Listing the First 5 Multiples of 6",
    "steps": [
      {
        "subgoalLabel": "Understand multiples",
        "instruction": "A multiple of 6 is the result of multiplying 6 by a whole number.",
        "work": "6 × 1, 6 × 2, 6 × 3, ...",
        "explanation": "Multiples are like skip counting: 6, 12, 18, ..."
      },
      {
        "subgoalLabel": "Calculate each multiple",
        "instruction": "Multiply 6 by 1, 2, 3, 4, and 5.",
        "work": "6 × 1 = 6\n6 × 2 = 12\n6 × 3 = 18\n6 × 4 = 24\n6 × 5 = 30",
        "explanation": "Each result is a multiple of 6."
      },
      {
        "subgoalLabel": "List the multiples",
        "instruction": "Write the first 5 multiples.",
        "work": "6, 12, 18, 24, 30",
        "explanation": "The first 5 multiples of 6 are 6, 12, 18, 24, 30."
      }
    ]
  },
  {
    "id": "multiples-of-number-ex2",
    "topicId": "multiples-of-number",
    "title": "Checking if 45 Is a Multiple of 9",
    "steps": [
      {
        "subgoalLabel": "Divide",
        "instruction": "Divide 45 by 9.",
        "work": "45 ÷ 9 = 5",
        "explanation": "If the division comes out even (no remainder), then 45 is a multiple of 9."
      },
      {
        "subgoalLabel": "Check the remainder",
        "instruction": "Is there a remainder?",
        "work": "No remainder. 9 × 5 = 45 exactly.",
        "explanation": "Since there is no remainder, 45 is a multiple of 9."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Is 45 a multiple of 9?",
        "work": "Yes, 45 is the 5th multiple of 9.",
        "explanation": "45 = 9 × 5, so it is a multiple of 9."
      }
    ]
  }
