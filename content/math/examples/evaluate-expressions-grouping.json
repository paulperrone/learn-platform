[
  {"id":"evaluate-expressions-grouping-ex1","topicId":"evaluate-expressions-grouping","title":"Evaluating with Parentheses and Brackets","steps":[{"subgoalLabel":"Identify groups","instruction":"Find the innermost grouping symbol.","work":"2 × [(4 + 3) × 5] — innermost is (4 + 3)","explanation":"Work from the inside out."},{"subgoalLabel":"Evaluate innermost","instruction":"Calculate (4 + 3).","work":"4 + 3 = 7","explanation":"Parentheses first."},{"subgoalLabel":"Evaluate brackets","instruction":"Calculate [7 × 5].","work":"7 × 5 = 35","explanation":"Now evaluate the brackets."},{"subgoalLabel":"Final calculation","instruction":"Multiply by 2.","work":"2 × 35 = 70","explanation":"The answer is 70."}]},
  {"id":"evaluate-expressions-grouping-ex2","topicId":"evaluate-expressions-grouping","title":"Nested Grouping Symbols","steps":[{"subgoalLabel":"Read the expression","instruction":"Identify all groups.","work":"{3 × [(10 − 4) + 2]} + 1","explanation":"Three levels: parentheses, brackets, braces."},{"subgoalLabel":"Innermost parentheses","instruction":"Calculate (10 − 4).","work":"10 − 4 = 6","explanation":"Start with the innermost group."},{"subgoalLabel":"Brackets","instruction":"Calculate [6 + 2].","work":"6 + 2 = 8","explanation":"Replace and evaluate the next level."},{"subgoalLabel":"Braces","instruction":"Calculate {3 × 8}.","work":"3 × 8 = 24","explanation":"Evaluate the outermost group."},{"subgoalLabel":"Final step","instruction":"Add 1.","work":"24 + 1 = 25","explanation":"The answer is 25."}]}
]
