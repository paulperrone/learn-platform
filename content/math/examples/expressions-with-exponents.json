[
  {"id":"expressions-with-exponents-ex1","topicId":"expressions-with-exponents","title":"Evaluating 2⁴","steps":[{"subgoalLabel":"Read the exponent","instruction":"Identify base and exponent.","work":"2⁴ means 2 is the base, 4 is the exponent.","explanation":"The exponent tells how many times to multiply the base by itself."},{"subgoalLabel":"Write as repeated multiplication","instruction":"Expand.","work":"2⁴ = 2 × 2 × 2 × 2","explanation":"Multiply 2 by itself 4 times."},{"subgoalLabel":"Calculate step by step","instruction":"Multiply left to right.","work":"2 × 2 = 4, 4 × 2 = 8, 8 × 2 = 16","explanation":"Each step multiplies the running total by 2."},{"subgoalLabel":"Final answer","instruction":"Write the result.","work":"2⁴ = 16","explanation":"2 to the 4th power equals 16."}]},
  {"id":"expressions-with-exponents-ex2","topicId":"expressions-with-exponents","title":"Evaluating an Expression with Exponents: 3² + 2³","steps":[{"subgoalLabel":"Evaluate each exponent separately","instruction":"Handle exponents before addition.","work":"3² = 3 × 3 = 9, 2³ = 2 × 2 × 2 = 8","explanation":"Exponents come first in order of operations."},{"subgoalLabel":"Add the results","instruction":"Add.","work":"9 + 8 = 17","explanation":"After evaluating exponents, add."},{"subgoalLabel":"Final answer","instruction":"Write the result.","work":"3² + 2³ = 17","explanation":"Always evaluate exponents before other operations."}]}
]
