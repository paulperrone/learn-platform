  {
    "id": "convert-decimal-to-fraction-ex1",
    "topicId": "convert-decimal-to-fraction",
    "title": "Converting 0.75 to a Fraction",
    "steps": [
      {
        "subgoalLabel": "Write as a fraction over a power of 10",
        "instruction": "0.75 has two decimal places, so write it over 100.",
        "work": "0.75 = 75/100",
        "explanation": "Two decimal places means hundredths."
      },
      {
        "subgoalLabel": "Find the GCF",
        "instruction": "The GCF of 75 and 100 is 25.",
        "work": "75 = 25 × 3, 100 = 25 × 4",
        "explanation": "Both 75 and 100 are divisible by 25."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Divide numerator and denominator by 25.",
        "work": "75/100 = 3/4",
        "explanation": "0.75 = 3/4."
      }
    ]
  },
  {
    "id": "convert-decimal-to-fraction-ex2",
    "topicId": "convert-decimal-to-fraction",
    "title": "Converting 0.125 to a Fraction",
    "steps": [
      {
        "subgoalLabel": "Write over a power of 10",
        "instruction": "0.125 has three decimal places, so write it over 1000.",
        "work": "0.125 = 125/1000",
        "explanation": "Three decimal places means thousandths."
      },
      {
        "subgoalLabel": "Simplify step by step",
        "instruction": "Divide both by 125.",
        "work": "125/1000 = 1/8",
        "explanation": "125 ÷ 125 = 1, and 1000 ÷ 125 = 8."
      },
      {
        "subgoalLabel": "Verify",
        "instruction": "Check: 1 ÷ 8 = 0.125.",
        "work": "1/8 = 0.125 ✓",
        "explanation": "0.125 = 1/8."
      }
    ]
  }
]
