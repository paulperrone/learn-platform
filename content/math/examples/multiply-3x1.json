        "subgoalLabel": "State the problem",
        "instruction": "Find 486 × 7.",
        "work": "486 × 7",
        "explanation": "This problem will require regrouping at every step."
      },
      {
        "subgoalLabel": "Multiply the ones",
        "instruction": "Find 6 × 7.",
        "work": "6 × 7 = 42. Write 2, carry 4.",
        "explanation": "42 ones = 4 tens and 2 ones."
      },
      {
        "subgoalLabel": "Multiply the tens",
        "instruction": "Find 8 × 7, then add the carry.",
        "work": "8 × 7 = 56, plus 4 = 60. Write 0, carry 6.",
        "explanation": "60 tens = 6 hundreds and 0 tens."
      },
      {
        "subgoalLabel": "Multiply the hundreds",
        "instruction": "Find 4 × 7, then add the carry.",
        "work": "4 × 7 = 28, plus 6 = 34. Write 34.",
        "explanation": "34 hundreds = 3 thousands and 4 hundreds."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 486 × 7?",
        "work": "486 × 7 = 3,402",
