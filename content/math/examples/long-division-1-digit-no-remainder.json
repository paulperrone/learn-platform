  {
    "id": "long-division-1-digit-no-remainder-ex1",
    "topicId": "long-division-1-digit-no-remainder",
    "title": "Long Division of a 2-Digit Number",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 84 ÷ 4 using long division.",
        "work": "Write 4 outside the division bracket and 84 inside.",
        "explanation": "The divisor goes outside and the dividend goes inside the long division symbol."
      },
      {
        "subgoalLabel": "Divide the tens",
        "instruction": "How many times does 4 go into 8?",
        "work": "8 ÷ 4 = 2. Write 2 above the 8.",
        "explanation": "4 goes into 8 exactly 2 times."
      },
      {
        "subgoalLabel": "Multiply and subtract",
        "instruction": "Multiply 2 × 4 and subtract from 8.",
        "work": "2 × 4 = 8. 8 - 8 = 0.",
        "explanation": "No remainder so far."
      },
      {
        "subgoalLabel": "Bring down and divide",
        "instruction": "Bring down the 4. Divide 4 ÷ 4.",
        "work": "Bring down 4 → 04. 4 ÷ 4 = 1. Write 1 above the 4.",
        "explanation": "4 ÷ 4 = 1. Multiply: 1 × 4 = 4. Subtract: 4 - 4 = 0. No remainder."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient from the top.",
        "work": "84 ÷ 4 = 21.",
        "explanation": "Check: 21 × 4 = 84 ✓."
      }
    ]
  },
  {
    "id": "long-division-1-digit-no-remainder-ex2",
    "topicId": "long-division-1-digit-no-remainder",
    "title": "Long Division of a 3-Digit Number",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 258 ÷ 6 using long division.",
        "work": "Write 6 outside the bracket and 258 inside.",
        "explanation": "We will divide digit by digit from left to right."
      },
      {
        "subgoalLabel": "Divide the first digit",
        "instruction": "How many times does 6 go into 2?",
        "work": "6 does not go into 2 (2 < 6). Take the first two digits: 25.",
        "explanation": "When the divisor is larger than the first digit, combine the first two digits."
      },
      {
        "subgoalLabel": "Divide 25 by 6",
        "instruction": "How many times does 6 go into 25?",
        "work": "25 ÷ 6 = 4 R 1. Write 4 above the 5. Multiply: 4 × 6 = 24. Subtract: 25 - 24 = 1.",
        "explanation": "6 × 4 = 24 is the largest multiple of 6 that fits in 25."
      },
      {
        "subgoalLabel": "Bring down and divide",
        "instruction": "Bring down the 8. Divide 18 ÷ 6.",
        "work": "Bring down 8 → 18. 18 ÷ 6 = 3. Write 3 above the 8. 3 × 6 = 18. 18 - 18 = 0.",
        "explanation": "No remainder."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient.",
        "work": "258 ÷ 6 = 43.",
        "explanation": "Check: 43 × 6 = 258 ✓."
      }
    ]
  }
]
