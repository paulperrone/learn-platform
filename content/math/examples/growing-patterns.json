    "title": "Growing Pattern with Changing Differences",
    "steps": [
      {"subgoalLabel": "Read the pattern", "instruction": "List the numbers.", "work": "1, 3, 6, 10, __", "explanation": "The differences between terms aren't always the same."},
      {"subgoalLabel": "Find the differences", "instruction": "Calculate the difference between each pair.", "work": "3 − 1 = 2, 6 − 3 = 3, 10 − 6 = 4", "explanation": "The differences are 2, 3, 4 — they increase by 1 each time."},
      {"subgoalLabel": "Predict the next difference", "instruction": "Continue the pattern of differences.", "work": "Next difference: 5", "explanation": "The differences go 2, 3, 4, 5."},
      {"subgoalLabel": "Find the next number", "instruction": "Add 5 to the last number.", "work": "10 + 5 = 15", "explanation": "The pattern continues: 1, 3, 6, 10, 15 (these are called triangular numbers)."}
