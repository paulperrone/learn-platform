      {"subgoalLabel": "Extend the pattern", "instruction": "Add 4 to the last number.", "work": "15 + 4 = 19", "explanation": "The next number is 19."},
      {"subgoalLabel": "Write the result", "instruction": "Complete the pattern.", "work": "3, 7, 11, 15, 19", "explanation": "Each number is 4 more than the previous one."}
