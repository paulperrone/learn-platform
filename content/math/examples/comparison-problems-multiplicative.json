    "title": "Times As Many (Multiplying)",
    "steps": [
      {"subgoalLabel": "Read the problem", "instruction": "Identify the quantities.", "work": "A garden has 6 roses. It has 4 times as many daisies.", "explanation": "We need to find the number of daisies."},
      {"subgoalLabel": "Set up multiplication", "instruction": "'Times as many' means multiply.", "work": "Daisies = 4 × 6", "explanation": "4 times as many as 6 means 4 × 6."},
      {"subgoalLabel": "Calculate", "instruction": "Multiply.", "work": "4 × 6 = 24", "explanation": "There are 24 daisies."},
      {"subgoalLabel": "Answer", "instruction": "Write the answer.", "work": "The garden has 24 daisies.", "explanation": "24 is 4 times as many as 6."}
