    "title": "How Many Times As Many? (Dividing)",
    "steps": [
      {"subgoalLabel": "Read the problem", "instruction": "Identify the quantities.", "work": "A library has 36 fiction books and 9 nonfiction books.", "explanation": "We need to find how many times as many fiction books there are."},
      {"subgoalLabel": "Set up division", "instruction": "'How many times as many' means divide.", "work": "36 ÷ 9 = ?", "explanation": "Divide the larger by the smaller."},
      {"subgoalLabel": "Calculate", "instruction": "Divide.", "work": "36 ÷ 9 = 4", "explanation": "There are 4 times as many fiction books."},
      {"subgoalLabel": "Verify", "instruction": "Check: 9 × 4 = 36?", "work": "9 × 4 = 36 ✓", "explanation": "Yes, 36 fiction books is 4 times 9 nonfiction books."}
