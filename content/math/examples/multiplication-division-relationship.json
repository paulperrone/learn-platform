[
  {
    "id": "multiplication-division-relationship-ex1",
    "topicId": "multiplication-division-relationship",
    "title": "Understanding Fact Families",
    "steps": [
      {
        "subgoalLabel": "Start with a multiplication fact",
        "instruction": "Begin with 4 × 9 = 36.",
        "work": "4 × 9 = 36",
        "explanation": "Every multiplication fact has related facts in its family."
      },
      {
        "subgoalLabel": "Write the other multiplication fact",
        "instruction": "Swap the factors.",
        "work": "9 × 4 = 36",
        "explanation": "The commutative property means order does not matter."
      },
      {
        "subgoalLabel": "Write the two division facts",
        "instruction": "Divide the product by each factor.",
        "work": "36 ÷ 4 = 9 and 36 ÷ 9 = 4.",
        "explanation": "Dividing the product by one factor gives the other factor."
      },
      {
        "subgoalLabel": "State the full fact family",
        "instruction": "List all four facts.",
        "work": "4 × 9 = 36, 9 × 4 = 36, 36 ÷ 4 = 9, 36 ÷ 9 = 4.",
        "explanation": "A fact family connects three numbers through multiplication and division."
      }
    ]
  },
  {
    "id": "multiplication-division-relationship-ex2",
    "topicId": "multiplication-division-relationship",
    "title": "Using Multiplication to Solve Division",
    "steps": [
      {
        "subgoalLabel": "State the division problem",
        "instruction": "Find 63 ÷ 7.",
        "work": "63 ÷ 7 = ?",
        "explanation": "Instead of dividing, think of a related multiplication."
      },
      {
        "subgoalLabel": "Rewrite as multiplication",
        "instruction": "Rewrite as: 7 × ? = 63.",
        "work": "7 × ? = 63",
        "explanation": "Division asks: what number times the divisor equals the dividend?"
      },
      {
        "subgoalLabel": "Use your multiplication facts",
        "instruction": "What times 7 equals 63?",
        "work": "7 × 9 = 63, so ? = 9.",
        "explanation": "Knowing multiplication facts makes division fast."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 63 ÷ 7?",
        "work": "63 ÷ 7 = 9",
        "explanation": "Multiplication and division are inverse operations. Knowing one helps you find the other."
      }
    ]
  }
]
