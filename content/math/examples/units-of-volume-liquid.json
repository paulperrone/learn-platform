[
  {"id":"units-of-volume-liquid-ex1","topicId":"units-of-volume-liquid","title":"Converting Gallons to Quarts","steps":[{"subgoalLabel":"Know the conversion","instruction":"How many quarts in 1 gallon?","work":"1 gallon = 4 quarts","explanation":"Key liquid volume conversion."},{"subgoalLabel":"Multiply","instruction":"Convert 3 gallons to quarts.","work":"3 × 4 = 12 quarts","explanation":"3 gallons contains 12 quarts."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"3 gallons = 12 quarts","explanation":"Larger to smaller: multiply."}]},
  {"id":"units-of-volume-liquid-ex2","topicId":"units-of-volume-liquid","title":"Customary Liquid Volume Chain","steps":[{"subgoalLabel":"Know the chain","instruction":"Learn the cup → pint → quart → gallon chain.","work":"2 cups = 1 pint, 2 pints = 1 quart, 4 quarts = 1 gallon","explanation":"Each step doubles (except quarts to gallons which is ×4)."},{"subgoalLabel":"Convert cups to gallons","instruction":"How many cups in 1 gallon?","work":"1 gal = 4 qt × 2 pt × 2 cups = 16 cups","explanation":"Multiply through the chain."},{"subgoalLabel":"Apply","instruction":"Convert 24 cups to gallons.","work":"24 ÷ 16 = 1.5 gallons","explanation":"24 cups = 1½ gallons."}]}
