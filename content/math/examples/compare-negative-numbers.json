        "subgoalLabel": "Order the negatives",
        "instruction": "Order -6, -3, -1 from least to greatest.",
        "work": "-6 < -3 < -1",
        "explanation": "The most negative (farthest from 0) is the least."
      },
      {
        "subgoalLabel": "Order the positives",
        "instruction": "Order 2, 5.",
        "work": "2 < 5",
        "explanation": "Positive numbers are ordered as usual."
      },
