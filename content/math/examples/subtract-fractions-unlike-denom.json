    "steps": [
      {
        "subgoalLabel": "Find the LCD",
        "instruction": "LCD of 6 and 4.",
        "work": "LCD = 12",
        "explanation": "The smallest number divisible by both 6 and 4 is 12."
      },
      {
        "subgoalLabel": "Convert fractions",
        "instruction": "Rewrite with denominator 12.",
        "work": "5/6 = 10/12, 1/4 = 3/12",
        "explanation": "5/6 × 2/2 = 10/12. 1/4 × 3/3 = 3/12."
      },
      {
        "subgoalLabel": "Subtract and simplify",
        "instruction": "Subtract and check if the result can be simplified.",
        "work": "10/12 − 3/12 = 7/12. GCF(7, 12) = 1 → already simplified.",
        "explanation": "7/12 is the final answer. Since 7 is prime and does not divide 12, no simplification is possible."
