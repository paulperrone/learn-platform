      },
      {
        "subgoalLabel": "Convert both fractions",
        "instruction": "Rewrite each fraction with denominator 12.",
        "work": "3/4 = 9/12 (×3), 1/3 = 4/12 (×4)",
        "explanation": "Multiply each fraction so both have the LCD as their denominator."
      },
      {
        "subgoalLabel": "Subtract",
        "instruction": "Subtract: 9/12 − 4/12.",
        "work": "9/12 − 4/12 = 5/12",
        "explanation": "With matching denominators, subtract the numerators: 9 − 4 = 5."
      }
