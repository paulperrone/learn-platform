[
  {"id":"weight-mass-intro-ex1","topicId":"weight-mass-intro","title":"Comparing Weights","steps":[{"subgoalLabel":"Read the weights","instruction":"A book weighs 2 pounds. A pillow weighs 1 pound.","work":"Book: 2 lb, Pillow: 1 lb","explanation":"We compare the numbers."},{"subgoalLabel":"Compare","instruction":"Which number is greater?","work":"2 > 1, so the book is heavier.","explanation":"The larger the number of pounds, the heavier the object."},{"subgoalLabel":"Find the difference","instruction":"How much heavier?","work":"2 − 1 = 1 pound heavier","explanation":"The book is 1 pound heavier than the pillow."}]},
  {"id":"weight-mass-intro-ex2","topicId":"weight-mass-intro","title":"Total Weight of Multiple Objects","steps":[{"subgoalLabel":"List the items","instruction":"3 books weigh 2 pounds each.","work":"3 books × 2 pounds each","explanation":"We need the total weight."},{"subgoalLabel":"Multiply","instruction":"Find total weight.","work":"3 × 2 = 6 pounds","explanation":"3 books at 2 pounds each = 6 pounds total."},{"subgoalLabel":"Answer","instruction":"State the total.","work":"The 3 books weigh 6 pounds altogether.","explanation":"Multiply when you have equal groups."}]}
