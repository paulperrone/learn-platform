    "title": "Multiplying 3/4 × 2/9 with Simplification",
    "steps": [
      {
        "subgoalLabel": "Multiply the numerators",
        "instruction": "Multiply the top numbers: 3 × 2.",
        "work": "3 × 2 = 6",
        "explanation": "Numerator of the product is 6."
      },
      {
        "subgoalLabel": "Multiply the denominators",
        "instruction": "Multiply the bottom numbers: 4 × 9.",
        "work": "4 × 9 = 36",
        "explanation": "Denominator of the product is 36."
      },
      {
        "subgoalLabel": "Write the unsimplified product",
        "instruction": "Put the numerator over the denominator.",
        "work": "3/4 × 2/9 = 6/36",
        "explanation": "We have 6/36, which can be simplified."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Find the GCF of 6 and 36, which is 6. Divide both by 6.",
        "work": "6/36 = 1/6",
        "explanation": "6 ÷ 6 = 1 and 36 ÷ 6 = 6, so the answer is 1/6."
      }
    ]
