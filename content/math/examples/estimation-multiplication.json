  {
    "id": "estimation-multiplication-ex1",
    "topicId": "estimation-multiplication",
    "title": "Estimating a Product by Rounding",
    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Estimate 38 × 7.",
        "work": "We want an approximate answer, not the exact one.",
        "explanation": "Estimation uses rounding to make multiplication easier."
      },
      {
        "subgoalLabel": "Round to a friendly number",
        "instruction": "Round 38 to the nearest ten.",
        "work": "38 rounds to 40.",
        "explanation": "38 is closer to 40 than to 30."
      },
      {
        "subgoalLabel": "Multiply the rounded numbers",
        "instruction": "Find 40 × 7.",
        "work": "40 × 7 = 280.",
        "explanation": "4 × 7 = 28, then add the zero: 280."
      },
      {
        "subgoalLabel": "State the estimate",
        "instruction": "What is the estimate for 38 × 7?",
        "work": "38 × 7 ≈ 280. (Exact: 266.)",
        "explanation": "The estimate of 280 is close to the exact answer of 266. Estimation helps check if an answer is reasonable."
      }
    ]
  },
  {
    "id": "estimation-multiplication-ex2",
    "topicId": "estimation-multiplication",
    "title": "Estimating with Two 2-Digit Numbers",
    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Estimate 47 × 62.",
        "work": "Both numbers can be rounded to the nearest ten.",
        "explanation": "When both factors are multi-digit, round each one."
      },
      {
        "subgoalLabel": "Round both factors",
        "instruction": "Round 47 and 62 to the nearest ten.",
        "work": "47 rounds to 50. 62 rounds to 60.",
        "explanation": "Choose the nearest ten for each."
      },
      {
        "subgoalLabel": "Multiply the rounded numbers",
        "instruction": "Find 50 × 60.",
        "work": "50 × 60 = 3,000.",
        "explanation": "5 × 6 = 30, then add two zeros: 3,000."
      },
      {
        "subgoalLabel": "State the estimate",
        "instruction": "What is the estimate for 47 × 62?",
        "work": "47 × 62 ≈ 3,000. (Exact: 2,914.)",
        "explanation": "The estimate is within about 100 of the exact answer. Good enough to check reasonableness."
      }
    ]
  }
