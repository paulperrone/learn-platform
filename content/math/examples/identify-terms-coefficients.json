[
  {"id":"identify-terms-coefficients-ex1","topicId":"identify-terms-coefficients","title":"Identifying Parts of 5x − 3y + 8","steps":[{"subgoalLabel":"Find the terms","instruction":"Split at + and − signs.","work":"Terms: 5x, −3y, 8","explanation":"Terms are separated by addition or subtraction."},{"subgoalLabel":"Find coefficients","instruction":"The coefficient is the number in front of the variable.","work":"Coefficient of x: 5. Coefficient of y: −3.","explanation":"The sign stays with the coefficient. −3y has coefficient −3."},{"subgoalLabel":"Find constants","instruction":"A constant has no variable.","work":"Constant: 8","explanation":"8 stands alone without any variable."},{"subgoalLabel":"Summary","instruction":"List everything.","work":"3 terms: 5x (coefficient 5), −3y (coefficient −3), 8 (constant)","explanation":"Every expression is made of terms, each with coefficients and/or constants."}]},
  {"id":"identify-terms-coefficients-ex2","topicId":"identify-terms-coefficients","title":"Hidden Coefficient of 1","steps":[{"subgoalLabel":"Read the expression","instruction":"Look at the expression.","work":"Expression: a + 2b − c + 4","explanation":"Some variables appear without a number."},{"subgoalLabel":"Find hidden coefficients","instruction":"When no number is written, the coefficient is 1 (or −1).","work":"a = 1a (coefficient 1). −c = −1c (coefficient −1).","explanation":"a means 1 × a. −c means −1 × c."},{"subgoalLabel":"List all parts","instruction":"Identify every term.","work":"1a (coeff 1), 2b (coeff 2), −1c (coeff −1), 4 (constant)","explanation":"4 terms total. The constant is 4."}]}
