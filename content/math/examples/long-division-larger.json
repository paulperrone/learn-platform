[
  {
    "id": "long-division-larger-ex1",
    "topicId": "long-division-larger",
    "title": "Long Division with a Large Dividend",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 15625 ÷ 25.",
        "work": "Write 25 outside and 15625 inside the division bracket.",
        "explanation": "The process is the same as shorter division — just more steps."
      },
      {
        "subgoalLabel": "First quotient digit",
        "instruction": "How many times does 25 go into 156?",
        "work": "25 × 6 = 150. Write 6. Subtract: 156 - 150 = 6.",
        "explanation": "25 × 7 = 175 which is too large."
      },
      {
        "subgoalLabel": "Second quotient digit",
        "instruction": "Bring down 2. How many times does 25 go into 62?",
        "work": "25 × 2 = 50. Write 2. Subtract: 62 - 50 = 12.",
        "explanation": "25 × 3 = 75 which is too large."
      },
      {
        "subgoalLabel": "Third quotient digit",
        "instruction": "Bring down 5. How many times does 25 go into 125?",
        "work": "25 × 5 = 125. Write 5. Subtract: 125 - 125 = 0.",
        "explanation": "Exact division — no remainder."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient.",
        "work": "15625 ÷ 25 = 625.",
        "explanation": "Check: 625 × 25 = 15625 ✓."
      }
    ]
  },
  {
    "id": "long-division-larger-ex2",
    "topicId": "long-division-larger",
    "title": "Long Division with Zeros in the Quotient (Large Numbers)",
    "steps": [
      {
        "subgoalLabel": "Set up",
        "instruction": "Divide 50400 ÷ 72.",
        "work": "Write 72 outside and 50400 inside.",
        "explanation": "Sometimes the quotient has zeros. Watch for them when the bring-down gives a number smaller than the divisor."
      },
      {
        "subgoalLabel": "First quotient digit",
        "instruction": "How many times does 72 go into 504?",
        "work": "72 × 7 = 504. Write 7. Subtract: 504 - 504 = 0.",
        "explanation": "Exact fit."
      },
      {
        "subgoalLabel": "Bring down — get 0",
        "instruction": "Bring down 0. 0 ÷ 72 = ?",
        "work": "0 ÷ 72 = 0. Write 0 in the quotient.",
        "explanation": "0 divided by anything is 0. Do not skip this digit."
      },
      {
        "subgoalLabel": "Bring down again",
        "instruction": "Bring down the final 0. 0 ÷ 72 = ?",
        "work": "0 ÷ 72 = 0. Write 0 in the quotient.",
        "explanation": "Another zero in the quotient."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "Read the quotient.",
        "work": "50400 ÷ 72 = 700.",
        "explanation": "Check: 700 × 72 = 50400 ✓. The zeros in the quotient are essential — without them the answer would be wrong."
      }
    ]
  }
]
