[
  {"id":"two-step-word-problems-ex1","topicId":"two-step-word-problems","title":"Add Then Subtract","steps":[{"subgoalLabel":"Read the problem","instruction":"Understand what happened.","work":"Sara had 12 balloons. She got 5 more, then 4 popped. How many does she have?","explanation":"Two things happen: getting more, then losing some."},{"subgoalLabel":"Step 1: Add","instruction":"Add the balloons she got.","work":"12 + 5 = 17","explanation":"She now has 17 balloons."},{"subgoalLabel":"Step 2: Subtract","instruction":"Subtract the ones that popped.","work":"17 − 4 = 13","explanation":"She has 13 balloons left."},{"subgoalLabel":"Answer","instruction":"Write the answer.","work":"Sara has 13 balloons.","explanation":"We added first, then subtracted."}]},
  {"id":"two-step-word-problems-ex2","topicId":"two-step-word-problems","title":"Multiply Then Subtract","steps":[{"subgoalLabel":"Read the problem","instruction":"Understand the situation.","work":"There are 4 bags with 5 oranges each. You eat 3 oranges. How many are left?","explanation":"First find the total, then subtract."},{"subgoalLabel":"Step 1: Multiply","instruction":"Find total oranges.","work":"4 × 5 = 20","explanation":"4 bags of 5 oranges = 20 oranges."},{"subgoalLabel":"Step 2: Subtract","instruction":"Remove the eaten oranges.","work":"20 − 3 = 17","explanation":"17 oranges remain."},{"subgoalLabel":"Answer","instruction":"State the answer.","work":"There are 17 oranges left.","explanation":"Multiply to find the total, then subtract what was used."}]}
]
