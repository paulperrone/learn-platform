[
  {"id":"evaluate-algebraic-expressions-ex1","topicId":"evaluate-algebraic-expressions","title":"Evaluating 3x + 5 when x = 4","steps":[{"subgoalLabel":"Identify the expression","instruction":"Read the expression and the given value.","work":"Expression: 3x + 5, where x = 4","explanation":"We substitute 4 for every x."},{"subgoalLabel":"Substitute","instruction":"Replace x with 4.","work":"3(4) + 5","explanation":"3x means 3 × x. Replace x with 4."},{"subgoalLabel":"Multiply first","instruction":"Follow order of operations.","work":"3(4) = 12","explanation":"Multiplication before addition."},{"subgoalLabel":"Add","instruction":"Complete the calculation.","work":"12 + 5 = 17","explanation":"When x = 4, the expression 3x + 5 equals 17."}]},
  {"id":"evaluate-algebraic-expressions-ex2","topicId":"evaluate-algebraic-expressions","title":"Evaluating with Two Variables","steps":[{"subgoalLabel":"Read the expression","instruction":"Note the variables and values.","work":"Expression: 2a − b + 3, where a = 5, b = 3","explanation":"Substitute both values."},{"subgoalLabel":"Substitute","instruction":"Replace a with 5 and b with 3.","work":"2(5) − 3 + 3","explanation":"Every a becomes 5, every b becomes 3."},{"subgoalLabel":"Multiply first","instruction":"Calculate 2(5).","work":"2(5) = 10","explanation":"Multiplication before subtraction/addition."},{"subgoalLabel":"Evaluate left to right","instruction":"Subtract then add.","work":"10 − 3 + 3 = 7 + 3 = 10","explanation":"The result is 10."}]}
]
