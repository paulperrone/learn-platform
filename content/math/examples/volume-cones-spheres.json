[
  {
    "id": "volume-cones-spheres-ex1",
    "topicId": "volume-cones-spheres",
    "title": "Volume of a Cone",
    "steps": [
      {
        "subgoalLabel": "Recall the formula",
        "instruction": "Volume of a cone = (1/3)πr²h. A cone is one-third the volume of a cylinder with the same base and height.",
        "work": "V = (1/3)πr²h",
        "explanation": "The 1/3 factor is because a cone tapers to a point."
      },
      {
        "subgoalLabel": "Calculate",
        "instruction": "A cone has radius 6 cm and height 10 cm.",
        "work": "V = (1/3) × π × 36 × 10 = (1/3) × 360π = 120π cu cm",
        "explanation": "Square the radius (36), multiply by height (360), then take one-third (120)."
      },
      {
        "subgoalLabel": "Approximate",
        "instruction": "Using π ≈ 3.14:",
        "work": "V ≈ 120 × 3.14 = 376.8 cu cm",
        "explanation": "Exact: 120π cu cm. Approximate: 376.8 cu cm."
      }
    ]
  },
  {
    "id": "volume-cones-spheres-ex2",
    "topicId": "volume-cones-spheres",
    "title": "Volume of a Sphere",
    "steps": [
      {
        "subgoalLabel": "Recall the formula",
        "instruction": "Volume of a sphere = (4/3)πr³.",
        "work": "V = (4/3)πr³",
        "explanation": "Note: this uses r cubed, not r squared."
      },
      {
        "subgoalLabel": "Calculate",
        "instruction": "A sphere has radius 5 cm.",
        "work": "V = (4/3) × π × 5³ = (4/3) × 125π = 500π/3 cu cm",
        "explanation": "Cube the radius (125), multiply by 4/3."
      },
      {
        "subgoalLabel": "Approximate",
        "instruction": "Using π ≈ 3.14:",
        "work": "V ≈ (500/3) × 3.14 ≈ 166.67 × 3.14 ≈ 523.33 cu cm",
        "explanation": "Exact: 500π/3 cu cm. Approximate: about 523.33 cu cm."
      }
    ]
  }
]