[
  {"id":"elapsed-time-ex1","topicId":"elapsed-time","title":"Finding Elapsed Time","steps":[{"subgoalLabel":"Note start and end","instruction":"Start: 2:15, End: 4:45","work":"Start: 2:15 PM, End: 4:45 PM","explanation":"We need to find how much time passed."},{"subgoalLabel":"Count the hours","instruction":"From 2:15 to 4:15 is 2 hours.","work":"2:15 → 4:15 = 2 hours","explanation":"Count full hours first."},{"subgoalLabel":"Count remaining minutes","instruction":"From 4:15 to 4:45.","work":"4:15 → 4:45 = 30 minutes","explanation":"Count the remaining minutes."},{"subgoalLabel":"Combine","instruction":"Add hours and minutes.","work":"2 hours + 30 minutes = 2 hours 30 minutes","explanation":"The elapsed time is 2 hours 30 minutes."}]},
  {"id":"elapsed-time-ex2","topicId":"elapsed-time","title":"Finding an End Time","steps":[{"subgoalLabel":"Read the problem","instruction":"A show starts at 7:40 and lasts 1 hour 35 minutes.","work":"Start: 7:40, Duration: 1 hr 35 min","explanation":"Add the duration to the start time."},{"subgoalLabel":"Add hours","instruction":"7:40 + 1 hour = 8:40.","work":"7:40 → 8:40","explanation":"Add the hours first."},{"subgoalLabel":"Add minutes","instruction":"8:40 + 35 minutes. 40 + 35 = 75 minutes = 1 hour 15 minutes.","work":"8:40 + 35 min → 8:75 → 9:15","explanation":"When minutes exceed 60, subtract 60 and add 1 to the hour."},{"subgoalLabel":"Answer","instruction":"The show ends at 9:15.","work":"End time: 9:15 PM","explanation":"7:40 + 1:35 = 9:15."}]}
