[
  {"id":"convert-length-larger-ex1","topicId":"convert-length-larger","title":"Converting Inches to Feet and Inches","steps":[{"subgoalLabel":"Know the conversion","instruction":"12 inches = 1 foot.","work":"Convert 54 inches to feet and inches.","explanation":"Divide by 12 to find feet."},{"subgoalLabel":"Divide","instruction":"54 ÷ 12.","work":"54 ÷ 12 = 4 remainder 6","explanation":"4 full feet with 6 inches remaining."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"54 inches = 4 feet 6 inches","explanation":"The quotient is feet, the remainder is inches."}]},
  {"id":"convert-length-larger-ex2","topicId":"convert-length-larger","title":"Converting Centimeters to Meters","steps":[{"subgoalLabel":"Know the conversion","instruction":"100 cm = 1 m.","work":"Convert 375 cm to meters and cm.","explanation":"Divide by 100 to find meters."},{"subgoalLabel":"Divide","instruction":"375 ÷ 100.","work":"375 ÷ 100 = 3 remainder 75","explanation":"3 full meters with 75 cm remaining."},{"subgoalLabel":"Answer","instruction":"State the result.","work":"375 cm = 3 m 75 cm","explanation":"Smaller to larger: divide."}]}
]
