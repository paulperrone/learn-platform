    "title": "Multiplying Two Fractions: 3/4 × 2/5",
    "steps": [
      {
        "subgoalLabel": "Multiply the numerators",
        "instruction": "Multiply the top numbers together.",
        "work": "3 × 2 = 6.",
        "explanation": "When multiplying fractions, multiply straight across — numerator times numerator."
      },
      {
        "subgoalLabel": "Multiply the denominators",
        "instruction": "Multiply the bottom numbers together.",
        "work": "4 × 5 = 20.",
        "explanation": "Denominator times denominator gives the new denominator."
      },
      {
        "subgoalLabel": "Simplify the result",
        "instruction": "Write the fraction and simplify.",
        "work": "6/20. GCF of 6 and 20 is 2. 6 ÷ 2 = 3, 20 ÷ 2 = 10. Answer: 3/10.",
        "explanation": "Always simplify the product to lowest terms."
      }
    ]
  },
  {
    "id": "multiply-fractions-ex2",
    "topicId": "multiply-fractions",
    "title": "Multiplying a Mixed Number by a Fraction: 1 2/3 × 3/5",
    "steps": [
      {
        "subgoalLabel": "Convert the mixed number",
        "instruction": "Convert 1 2/3 to an improper fraction.",
        "work": "1 2/3 = (1 × 3 + 2)/3 = 5/3.",
        "explanation": "Multiply the whole number by the denominator and add the numerator."
      },
      {
        "subgoalLabel": "Multiply the fractions",
        "instruction": "Multiply 5/3 × 3/5.",
        "work": "Numerators: 5 × 3 = 15. Denominators: 3 × 5 = 15. Result: 15/15.",
        "explanation": "Multiply straight across for both numerator and denominator."
      },
      {
        "subgoalLabel": "Simplify",
        "instruction": "Simplify 15/15.",
        "work": "15/15 = 1.",
        "explanation": "When the numerator equals the denominator, the fraction equals 1. We could have also cross-cancelled before multiplying: the 3s and 5s cancel."
      }
    ]
  }
