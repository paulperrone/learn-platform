[
  {"id":"multi-step-word-problems-4ops-ex1","topicId":"multi-step-word-problems-4ops","title":"Two Operations: Multiply Then Add","steps":[{"subgoalLabel":"Read the problem","instruction":"Understand what's asked.","work":"A box has 8 muffins. You buy 3 boxes and then bake 5 more muffins. How many total?","explanation":"Two steps: find total from boxes, then add extra."},{"subgoalLabel":"Step 1: Multiply","instruction":"Find total from boxes.","work":"3 × 8 = 24 muffins","explanation":"3 boxes with 8 muffins each."},{"subgoalLabel":"Step 2: Add","instruction":"Add the extra muffins.","work":"24 + 5 = 29 muffins","explanation":"The total is 29 muffins."},{"subgoalLabel":"Answer","instruction":"Write a sentence.","work":"There are 29 muffins in all.","explanation":"Always re-read the question to make sure you answered what was asked."}]},
  {"id":"multi-step-word-problems-4ops-ex2","topicId":"multi-step-word-problems-4ops","title":"Add Then Divide","steps":[{"subgoalLabel":"Read the problem","instruction":"Understand the situation.","work":"Lisa earned $18 on Saturday and $12 on Sunday. She splits the total equally with her brother.","explanation":"First find the total, then divide."},{"subgoalLabel":"Step 1: Add","instruction":"Find total earnings.","work":"$18 + $12 = $30","explanation":"Combined earnings over both days."},{"subgoalLabel":"Step 2: Divide","instruction":"Split equally between 2 people.","work":"$30 ÷ 2 = $15","explanation":"Each person gets $15."},{"subgoalLabel":"Answer","instruction":"Write the answer.","work":"Each person gets $15.","explanation":"Lisa and her brother each get $15."}]}
]
