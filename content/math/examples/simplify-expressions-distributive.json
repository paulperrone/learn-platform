[
  {"id":"simplify-expressions-distributive-ex1","topicId":"simplify-expressions-distributive","title":"Simplify 3(x + 4) + 2x","steps":[{"subgoalLabel":"Distribute","instruction":"Multiply 3 by each term inside parentheses.","work":"3(x + 4) = 3x + 12","explanation":"3 × x = 3x and 3 × 4 = 12."},{"subgoalLabel":"Rewrite","instruction":"Replace the distributed expression.","work":"3x + 12 + 2x","explanation":"Now combine like terms."},{"subgoalLabel":"Combine like terms","instruction":"Group x-terms.","work":"3x + 2x + 12 = 5x + 12","explanation":"3x + 2x = 5x. The constant 12 stays."},{"subgoalLabel":"Final answer","instruction":"Write the simplified expression.","work":"5x + 12","explanation":"We distributed, then combined like terms."}]},
  {"id":"simplify-expressions-distributive-ex2","topicId":"simplify-expressions-distributive","title":"Simplify 2(a + 3) − (a − 1)","steps":[{"subgoalLabel":"Distribute first group","instruction":"Multiply 2 by each term.","work":"2(a + 3) = 2a + 6","explanation":"2 × a = 2a and 2 × 3 = 6."},{"subgoalLabel":"Distribute second group","instruction":"Subtract means distribute −1.","work":"−(a − 1) = −a + 1","explanation":"−1 × a = −a and −1 × (−1) = +1."},{"subgoalLabel":"Combine","instruction":"Put together and combine like terms.","work":"2a + 6 − a + 1 = a + 7","explanation":"2a − a = a. 6 + 1 = 7."},{"subgoalLabel":"Final answer","instruction":"Write it.","work":"a + 7","explanation":"Always remember to distribute the negative sign!"}]}
]
