[
  {"id":"factor-numerical-expressions-ex1","topicId":"factor-numerical-expressions","title":"Factoring 24 + 16 Using the GCF","steps":[{"subgoalLabel":"Find factors of each","instruction":"List factors of 24 and 16.","work":"24: 1,2,3,4,6,8,12,24. 16: 1,2,4,8,16.","explanation":"We need the greatest factor they share."},{"subgoalLabel":"Find the GCF","instruction":"Identify the largest common factor.","work":"Common factors: 1, 2, 4, 8. GCF = 8.","explanation":"8 is the greatest common factor."},{"subgoalLabel":"Divide each by GCF","instruction":"Divide both numbers by 8.","work":"24 ÷ 8 = 3, 16 ÷ 8 = 2","explanation":"These become the numbers inside parentheses."},{"subgoalLabel":"Write factored form","instruction":"Express as GCF × (sum).","work":"24 + 16 = 8(3 + 2)","explanation":"Check: 8 × 5 = 40 = 24 + 16 ✓"}]},
  {"id":"factor-numerical-expressions-ex2","topicId":"factor-numerical-expressions","title":"Factoring Three Numbers: 15 + 25 + 10","steps":[{"subgoalLabel":"Find GCF of all three","instruction":"Find the GCF of 15, 25, and 10.","work":"Factors of 15: 1,3,5,15. Factors of 25: 1,5,25. Factors of 10: 1,2,5,10. GCF = 5.","explanation":"5 is the only common factor greater than 1."},{"subgoalLabel":"Divide each by 5","instruction":"Divide.","work":"15÷5=3, 25÷5=5, 10÷5=2","explanation":"Each number divided by the GCF."},{"subgoalLabel":"Write factored form","instruction":"Express result.","work":"15 + 25 + 10 = 5(3 + 5 + 2)","explanation":"Check: 5 × 10 = 50 = 15 + 25 + 10 ✓"}]}
]
