[
  {
    "id": "supplementary-angles-ex1",
    "topicId": "supplementary-angles",
    "title": "Finding the Supplement of an Angle",
    "steps": [
      {
        "subgoalLabel": "Recall the definition",
        "instruction": "What are supplementary angles?",
        "work": "Two angles are supplementary if they add up to 180° (a straight angle).",
        "explanation": "Think of two angles fitting together to form a straight line."
      },
      {
        "subgoalLabel": "Set up the subtraction",
        "instruction": "Find the supplement of 65°.",
        "work": "supplement = 180° − 65°",
        "explanation": "Subtract the known angle from 180°."
      },
      {
        "subgoalLabel": "Calculate and verify",
        "instruction": "Solve and check.",
        "work": "180° − 65° = 115°. Check: 65° + 115° = 180°. ✓",
        "explanation": "The supplement of 65° is 115°."
      }
    ]
  },
  {
    "id": "supplementary-angles-ex2",
    "topicId": "supplementary-angles",
    "title": "Supplementary Angles in a Ratio",
    "steps": [
      {
        "subgoalLabel": "Set up the problem",
        "instruction": "Two supplementary angles are in the ratio 5:4. Find both.",
        "work": "The angles are in ratio 5:4 and sum to 180°.",
        "explanation": "We need to divide 180° into parts according to the ratio."
      },
      {
        "subgoalLabel": "Find total parts",
        "instruction": "How many parts total?",
        "work": "5 + 4 = 9 parts.",
        "explanation": "The ratio tells us the 180° is split into 9 equal portions."
      },
      {
        "subgoalLabel": "Find the value of one part",
        "instruction": "Divide 180° by 9.",
        "work": "180° ÷ 9 = 20° per part.",
        "explanation": "Each portion equals 20°."
      },
      {
        "subgoalLabel": "Calculate each angle",
        "instruction": "Multiply by the ratio numbers.",
        "work": "Angle 1: 5 × 20° = 100°. Angle 2: 4 × 20° = 80°. Check: 100° + 80° = 180°. ✓",
        "explanation": "The two supplementary angles are 100° and 80°."
      }
    ]
  }
]