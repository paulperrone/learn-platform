    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Find 9 × 7.",
        "work": "9 × 7 means 9 groups of 7.",
        "explanation": "The 9s can be tricky, but there is a helpful strategy."
      },
      {
        "subgoalLabel": "Use 10 groups instead",
        "instruction": "First find 10 × 7.",
        "work": "10 × 7 = 70.",
        "explanation": "It is easy to multiply by 10. We will adjust from there."
      },
      {
        "subgoalLabel": "Subtract one group",
        "instruction": "9 groups is one less than 10 groups. Subtract one group of 7.",
        "work": "70 − 7 = 63.",
        "explanation": "Since we used 10 groups but only need 9, we take away one group."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 9 × 7?",
        "work": "9 × 7 = 63",
        "explanation": "Strategy: 9 × n = 10 × n − n. This works for all 9s facts."
      }
