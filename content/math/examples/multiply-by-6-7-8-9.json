    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Find 6 × 8.",
        "work": "6 × 8 means 6 groups of 8.",
        "explanation": "We can break 6 into parts we already know."
      },
      {
        "subgoalLabel": "Break 6 into 5 + 1",
        "instruction": "Find 5 × 8 and 1 × 8 separately.",
        "work": "5 × 8 = 40 and 1 × 8 = 8.",
        "explanation": "6 groups = 5 groups + 1 group. We know the 5s facts well."
      },
      {
        "subgoalLabel": "Add the parts",
        "instruction": "Add the two partial products.",
        "work": "40 + 8 = 48.",
        "explanation": "6 × 8 = (5 × 8) + (1 × 8) = 40 + 8 = 48."
      },
      {
        "subgoalLabel": "State the answer",
        "instruction": "What is 6 × 8?",
        "work": "6 × 8 = 48",
        "explanation": "Breaking a harder fact into easier ones is a powerful strategy."
      }
    ]
