    "title": "Adding Three-Digit Numbers with Regrouping: 257 + 168",
    "steps": [
      {
        "subgoalLabel": "Add the ones",
        "instruction": "Add the ones digits: 7 + 8.",
        "work": "7 + 8 = 15. Write 5, carry 1.",
        "explanation": "15 ones = 1 ten and 5 ones. We regroup by carrying the 1 ten."
      },
      {
        "subgoalLabel": "Add the tens",
        "instruction": "Add the tens digits plus the carried 1: 5 + 6 + 1.",
        "work": "5 + 6 + 1 = 12. Write 2, carry 1.",
        "explanation": "12 tens = 1 hundred and 2 tens. Carry the 1 hundred."
      },
      {
        "subgoalLabel": "Add the hundreds",
        "instruction": "Add the hundreds digits plus the carried 1: 2 + 1 + 1.",
        "work": "2 + 1 + 1 = 4",
        "explanation": "Remember to include any carried amount."
      },
      {
        "subgoalLabel": "Write the answer",
        "instruction": "Combine all places.",
        "work": "257 + 168 = 425",
        "explanation": "4 hundreds, 2 tens, 5 ones = 425."
      }
    ]
  },
