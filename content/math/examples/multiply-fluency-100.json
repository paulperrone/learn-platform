    "steps": [
      {
        "subgoalLabel": "State the problem",
        "instruction": "Find 9 × 6 quickly.",
        "work": "We need 9 × 6.",
        "explanation": "Let's use the tens strategy for 9s."
      },
      {
        "subgoalLabel": "Multiply by 10 instead",
        "instruction": "Find 10 × 6.",
