[
  {"id":"money-word-problems-ex1","topicId":"money-word-problems","title":"Buying Multiple Items","steps":[{"subgoalLabel":"Read the problem","instruction":"You buy 3 erasers at $0.75 each and 2 pencils at $0.50 each.","work":"Erasers: 3 × $0.75, Pencils: 2 × $0.50","explanation":"Find each cost separately, then add."},{"subgoalLabel":"Calculate each cost","instruction":"Multiply.","work":"Erasers: 3 × $0.75 = $2.25. Pencils: 2 × $0.50 = $1.00.","explanation":"Find the cost of each type of item."},{"subgoalLabel":"Add for total","instruction":"Combine both costs.","work":"$2.25 + $1.00 = $3.25","explanation":"The total cost is $3.25."},{"subgoalLabel":"Find change","instruction":"You pay with $5. What's the change?","work":"$5.00 − $3.25 = $1.75","explanation":"You get $1.75 in change."}]},
  {"id":"money-word-problems-ex2","topicId":"money-word-problems","title":"Saving Up for a Goal","steps":[{"subgoalLabel":"Read the problem","instruction":"A game costs $15. You save $2.50 per week. How many weeks?","work":"$15 ÷ $2.50 = ?","explanation":"Divide the goal by the weekly savings."},{"subgoalLabel":"Divide","instruction":"Calculate.","work":"$15.00 ÷ $2.50 = 6","explanation":"It takes exactly 6 weeks."},{"subgoalLabel":"Verify","instruction":"Check: 6 × $2.50 = $15?","work":"6 × $2.50 = $15.00 ✓","explanation":"After 6 weeks of saving $2.50, you'll have exactly $15."}]}
