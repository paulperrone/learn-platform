{
  "description": "United States history from pre-colonial Indigenous peoples through contemporary America. Context-layered progression: survey depth covers key events and figures, contextual depth explores causes and connections. Aligned to C3 Framework and state social studies standards.",
  "disciplineId": "history",
  "topics": [
    {
      "id": "indigenous-peoples",
      "name": "Indigenous Peoples of North America",
      "description": "Major Indigenous groups, their regions, cultures, and ways of life before European contact.",
      "gradeLevel": 3,
      "standardCode": "D2.His.3.3-5",
      "strand": "colonial-era",
      "contentDepth": "survey",
      "defaultPresentation": "intermediate"
    },
    {
      "id": "european-exploration",
      "name": "European Exploration",
      "description": "Why and how Europeans explored the Americas: Columbus, Spanish conquistadors, French and English explorers.",
      "gradeLevel": 3,
      "standardCode": "D2.His.1.3-5",
      "strand": "colonial-era",
      "contentDepth": "survey",
      "defaultPresentation": "intermediate"
    },
    {
      "id": "colonial-life",
      "name": "Colonial Life in the Thirteen Colonies",
      "description": "Daily life, economy, and society in the New England, Middle, and Southern colonies.",
      "gradeLevel": 4,
      "standardCode": "D2.His.2.3-5",
      "strand": "colonial-era",
      "contentDepth": "survey",
      "defaultPresentation": "intermediate"
    },
    {
      "id": "colonial-economies",
      "name": "Colonial Economies and Trade",
      "description": "Triangular trade, cash crops, mercantilism, and economic differences between colonial regions.",
